@using System.Text
@using Nncase.CodeGen.PyNTT
@model Nncase.CodeGen.PyNTT.PyNTTConv2DTemplateModel
@{
    var inputShape = PyNTTTemplateUtility.ShapeTuple(Model.InputShape);
    var weightsShape = PyNTTTemplateUtility.ShapeTuple(Model.WeightsShape);
    var outputShape = PyNTTTemplateUtility.ShapeTuple(Model.OutputShape);
    var strideH = Model.Stride[0];
    var strideW = Model.Stride[1];
    var padTop = Model.Padding[0];
    var padLeft = Model.Padding[2];
    var dilationH = Model.Dilation[0];
    var dilationW = Model.Dilation[1];
    var inputChannelsPerGroup = PyNTTTemplateUtility.RequireFixed(Model.WeightsShape[1], "Conv2D input channels per group");
    var outputChannelsPerGroup = PyNTTTemplateUtility.RequireFixed(Model.OutputShape[1], "Conv2D output channels") / Model.Groups;
    var kernelH = PyNTTTemplateUtility.RequireFixed(Model.WeightsShape[2], "Conv2D kernel height");
    var kernelW = PyNTTTemplateUtility.RequireFixed(Model.WeightsShape[3], "Conv2D kernel width");

    static string Indent(int level) => new(' ', level * 4);

    var blockAxis = PyNTTTemplateUtility.SelectBlockAxis(Model.OutputShape, Model.OutputStrides);
    var blockExtent = Model.OutputShape[blockAxis];
    var loopAxes = Enumerable.Range(0, Model.OutputShape.Length).Where(axis => axis != blockAxis).ToArray();

    string AxisIndex(int axis) => axis == blockAxis ? "lane" : $"idx{axis}";

    var n = AxisIndex(0);
    var oc = AxisIndex(1);
    var oh = AxisIndex(2);
    var ow = AxisIndex(3);
    var group = Model.Groups == 1 ? "0" : $"{oc} // {outputChannelsPerGroup}";
    var inputChannel = Model.Groups == 1
        ? "ic"
        : $"({group}) * {inputChannelsPerGroup} + ic";
    var ih = $"{oh} * {strideH} + kh * {dilationH} - {padTop}";
    var iw = $"{ow} * {strideW} + kw * {dilationW} - {padLeft}";
    var inputOffset = $"lane * 0 + {n} * {Model.InputStrides[0]} + ({inputChannel}) * {Model.InputStrides[1]} + ({ih}) * {Model.InputStrides[2]} + ({iw}) * {Model.InputStrides[3]}";
    var weightsOffset = $"lane * 0 + {oc} * {Model.WeightsStrides[0]} + ic * {Model.WeightsStrides[1]} + kh * {Model.WeightsStrides[2]} + kw * {Model.WeightsStrides[3]}";
    var biasOffset = $"lane * 0 + {oc} * {Model.BiasStrides[0]}";
    var outputOffset = $"lane * 0 + {n} * {Model.OutputStrides[0]} + {oc} * {Model.OutputStrides[1]} + {oh} * {Model.OutputStrides[2]} + {ow} * {Model.OutputStrides[3]}";

    var body = new StringBuilder();
    var indent = 1;
    foreach (var axis in loopAxes)
    {
        body.AppendLine($"{Indent(indent)}for idx{axis} in tl.range(0, {Model.OutputShape[axis]}):");
        indent++;
    }

    body.AppendLine($"{Indent(indent)}for axis_start in tl.range(0, {blockExtent}, block_size):");
    body.AppendLine($"{Indent(indent + 1)}lane = axis_start + tl.arange(0, block_size)");
    body.AppendLine($"{Indent(indent + 1)}mask = lane < {blockExtent}");
    body.AppendLine($"{Indent(indent + 1)}acc = tl.load(bias + {biasOffset}, mask=mask, other=0.0).to(tl.float32)");
    body.AppendLine($"{Indent(indent + 1)}for ic in tl.range(0, {inputChannelsPerGroup}):");
    body.AppendLine($"{Indent(indent + 2)}for kh in tl.range(0, {kernelH}):");
    body.AppendLine($"{Indent(indent + 3)}for kw in tl.range(0, {kernelW}):");
    body.AppendLine($"{Indent(indent + 4)}ih = {ih}");
    body.AppendLine($"{Indent(indent + 4)}iw = {iw}");
    body.AppendLine($"{Indent(indent + 4)}input_mask = mask & (ih >= 0) & (ih < {Model.InputShape[2]}) & (iw >= 0) & (iw < {Model.InputShape[3]})");
    body.AppendLine($"{Indent(indent + 4)}input_value = tl.load(input + {inputOffset}, mask=input_mask, other=0.0).to(tl.float32)");
    body.AppendLine($"{Indent(indent + 4)}weight_value = tl.load(weights + {weightsOffset}, mask=mask, other=0.0).to(tl.float32)");
    body.AppendLine($"{Indent(indent + 4)}acc += input_value * weight_value");
    body.AppendLine($"{Indent(indent + 1)}tl.store(output + {outputOffset}, acc.to({Model.OutputTritonDType}), mask=mask)");

    foreach (var axis in loopAxes.Reverse())
    {
        indent--;
    }
}
