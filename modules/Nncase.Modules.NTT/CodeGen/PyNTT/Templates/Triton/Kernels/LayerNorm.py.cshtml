@using System.Globalization
@using System.Text
@using Nncase.CodeGen.PyNTT
@model Nncase.CodeGen.PyNTT.PyNTTLayerNormTemplateModel
@{
    var inputShape = PyNTTTemplateUtility.ShapeTuple(Model.InputShape);
    var outputShape = PyNTTTemplateUtility.ShapeTuple(Model.OutputShape);
    var scaleShape = PyNTTTemplateUtility.ShapeTuple(Model.ScaleShape);
    var biasShape = PyNTTTemplateUtility.ShapeTuple(Model.BiasShape);
    static PyNTTDimExpression MultiplyDim(PyNTTDimExpression dim, int lane)
    {
        if (lane == 1)
        {
            return dim;
        }

        var fixedValue = dim.FixedValue.HasValue ? checked(dim.FixedValue.Value * lane) : (long?)null;
        return new($"({dim.PythonExpression} * {lane})", $"({dim.TritonExpression} * {lane})", fixedValue);
    }

    static PyNTTDimExpression[] LogicalShape(PyNTTDimExpression[] physicalShape, int laneCount)
    {
        var logicalShape = physicalShape.ToArray();
        if (laneCount > 1)
        {
            logicalShape[^1] = MultiplyDim(logicalShape[^1], laneCount);
        }

        return logicalShape;
    }

    var logicalInputShape = LogicalShape(Model.InputShape, Model.InputVectorLaneCount);
    var logicalScaleShape = LogicalShape(Model.ScaleShape, Model.ScaleVectorLaneCount);
    var logicalBiasShape = LogicalShape(Model.BiasShape, Model.BiasVectorLaneCount);
    var logicalOutputShape = LogicalShape(Model.OutputShape, Model.OutputVectorLaneCount);
    var rank = logicalOutputShape.Length;
    var innerAxes = Enumerable.Range(Model.Axis, rank - Model.Axis).ToArray();
    var outerAxes = Enumerable.Range(0, Model.Axis).ToArray();
    var epsilon = Model.Epsilon.ToString("R", CultureInfo.InvariantCulture);

    static string Indent(int level) => new(' ', level * 4);

    string ProductExpression(IEnumerable<PyNTTDimExpression> dimensions)
    {
        var dims = dimensions.ToArray();
        return dims.Length == 0
            ? "1"
            : string.Join(" * ", dims.Select(dim => $"({dim.TritonExpression})"));
    }

    string AxisIndex(int axis) => axis < Model.Axis ? $"outer_idx{axis}" : $"inner_idx{axis}";

    string TensorOffsetExpression(PyNTTDimExpression[] physicalShape, PyNTTDimExpression[] logicalShape, PyNTTDimExpression[] strides, int laneCount)
    {
        var terms = new List<string>();
        for (var axis = 0; axis < rank; axis++)
        {
            if (logicalShape[axis].IsFixedOne)
            {
                continue;
            }

            var index = AxisIndex(axis);
            if (laneCount > 1 && axis == physicalShape.Length - 1)
            {
                index = $"(({index}) // {laneCount})";
            }

            terms.Add($"{index} * {strides[axis]}");
        }

        var physicalIndex = terms.Count == 0 ? "inner_lane * 0" : $"inner_lane * 0 + {string.Join(" + ", terms)}";
        if (laneCount == 1)
        {
            return physicalIndex;
        }

        var laneIndex = $"(({AxisIndex(physicalShape.Length - 1)}) % {laneCount})";
        return $"(({physicalIndex}) * {laneCount} + {laneIndex})";
    }

    string ParameterOffsetExpression(PyNTTDimExpression[] physicalShape, PyNTTDimExpression[] logicalShape, PyNTTDimExpression[] strides, int laneCount)
    {
        var terms = new List<string>();
        for (var axis = 0; axis < logicalShape.Length; axis++)
        {
            if (logicalShape[axis].IsFixedOne)
            {
                continue;
            }

            var outputAxis = Model.Axis + axis;
            var index = AxisIndex(outputAxis);
            if (laneCount > 1 && axis == physicalShape.Length - 1)
            {
                index = $"(({index}) // {laneCount})";
            }

            terms.Add($"{index} * {strides[axis]}");
        }

        var physicalIndex = terms.Count == 0 ? "inner_lane * 0" : $"inner_lane * 0 + {string.Join(" + ", terms)}";
        if (laneCount == 1)
        {
            return physicalIndex;
        }

        var laneIndex = $"(({AxisIndex(Model.Axis + physicalShape.Length - 1)}) % {laneCount})";
        return $"(({physicalIndex}) * {laneCount} + {laneIndex})";
    }

    void AppendInnerIndexDecode(StringBuilder builder, int indent)
    {
        builder.AppendLine($"{Indent(indent)}inner_remaining = inner_lane");
        foreach (var axis in innerAxes.Reverse())
        {
            builder.AppendLine($"{Indent(indent)}inner_idx{axis} = inner_remaining % {logicalOutputShape[axis]}");
            builder.AppendLine($"{Indent(indent)}inner_remaining = inner_remaining // {logicalOutputShape[axis]}");
        }
    }

    var innerSize = ProductExpression(logicalOutputShape.Skip(Model.Axis));
    var inputOffset = TensorOffsetExpression(Model.InputShape, logicalInputShape, Model.InputStrides, Model.InputVectorLaneCount);
    var outputOffset = TensorOffsetExpression(Model.OutputShape, logicalOutputShape, Model.OutputStrides, Model.OutputVectorLaneCount);
    var scaleOffset = ParameterOffsetExpression(Model.ScaleShape, logicalScaleShape, Model.ScaleStrides, Model.ScaleVectorLaneCount);
    var biasOffset = ParameterOffsetExpression(Model.BiasShape, logicalBiasShape, Model.BiasStrides, Model.BiasVectorLaneCount);

    var body = new StringBuilder();
    var indent = 1;
    foreach (var axis in outerAxes)
    {
        body.AppendLine($"{Indent(indent)}for outer_idx{axis} in tl.range(0, {logicalOutputShape[axis]}):");
        indent++;
    }

    body.AppendLine($"{Indent(indent)}inner_size = {innerSize}");
    body.AppendLine($"{Indent(indent)}inner_count = inner_size + 0.0");
    if (Model.UseMean)
    {
        body.AppendLine($"{Indent(indent)}mean_sum = tl.full((), 0.0, tl.float32)");
        body.AppendLine($"{Indent(indent)}for inner_start in tl.range(0, inner_size, block_size):");
        body.AppendLine($"{Indent(indent + 1)}inner_lane = inner_start + tl.arange(0, block_size)");
        body.AppendLine($"{Indent(indent + 1)}mask = inner_lane < inner_size");
        AppendInnerIndexDecode(body, indent + 1);
        body.AppendLine($"{Indent(indent + 1)}input_offsets = {inputOffset}");
        body.AppendLine($"{Indent(indent + 1)}value0 = tl.load(input0 + input_offsets, mask=mask, other=0.0).to(tl.float32)");
        body.AppendLine($"{Indent(indent + 1)}mean_sum += tl.sum(value0, axis=0)");
        body.AppendLine($"{Indent(indent)}mean_value = mean_sum / inner_count");
    }
    else
    {
        body.AppendLine($"{Indent(indent)}mean_value = 0.0");
    }

    body.AppendLine($"{Indent(indent)}variance_sum = tl.full((), 0.0, tl.float32)");
    body.AppendLine($"{Indent(indent)}for inner_start in tl.range(0, inner_size, block_size):");
    body.AppendLine($"{Indent(indent + 1)}inner_lane = inner_start + tl.arange(0, block_size)");
    body.AppendLine($"{Indent(indent + 1)}mask = inner_lane < inner_size");
    AppendInnerIndexDecode(body, indent + 1);
    body.AppendLine($"{Indent(indent + 1)}input_offsets = {inputOffset}");
    body.AppendLine($"{Indent(indent + 1)}value0 = tl.load(input0 + input_offsets, mask=mask, other=0.0).to(tl.float32)");
    body.AppendLine($"{Indent(indent + 1)}centered = value0 - mean_value");
    body.AppendLine($"{Indent(indent + 1)}variance_sum += tl.sum(centered * centered, axis=0)");
    body.AppendLine($"{Indent(indent)}inv_std = tl.rsqrt((variance_sum / inner_count) + {epsilon})");
    body.AppendLine($"{Indent(indent)}for inner_start in tl.range(0, inner_size, block_size):");
    body.AppendLine($"{Indent(indent + 1)}inner_lane = inner_start + tl.arange(0, block_size)");
    body.AppendLine($"{Indent(indent + 1)}mask = inner_lane < inner_size");
    AppendInnerIndexDecode(body, indent + 1);
    body.AppendLine($"{Indent(indent + 1)}input_offsets = {inputOffset}");
    body.AppendLine($"{Indent(indent + 1)}scale_offsets = {scaleOffset}");
    body.AppendLine($"{Indent(indent + 1)}bias_offsets = {biasOffset}");
    body.AppendLine($"{Indent(indent + 1)}output_offsets = {outputOffset}");
    body.AppendLine($"{Indent(indent + 1)}value0 = tl.load(input0 + input_offsets, mask=mask, other=0.0).to(tl.float32)");
    body.AppendLine($"{Indent(indent + 1)}scale_value = tl.load(scale0 + scale_offsets, mask=mask, other=0.0).to(tl.float32)");
    body.AppendLine($"{Indent(indent + 1)}bias_value = tl.load(bias0 + bias_offsets, mask=mask, other=0.0).to(tl.float32)");
    body.AppendLine($"{Indent(indent + 1)}result = ((value0 - mean_value) * inv_std * scale_value) + bias_value");
    body.AppendLine($"{Indent(indent + 1)}tl.store(output + output_offsets, result, mask=mask)");

    foreach (var axis in outerAxes.Reverse())
    {
        indent--;
    }
}
# generated from CodeGen/PyNTT/Templates/Triton/Kernels/LayerNorm.py.cshtml
# @Model.Comment; input_dtype=@Model.InputDType, scale_dtype=@Model.ScaleDType, bias_dtype=@Model.BiasDType, output_dtype=@Model.OutputDType, input_shape=@inputShape, scale_shape=@scaleShape, bias_shape=@biasShape, output_shape=@outputShape, axis=@Model.Axis, use_mean=@Model.UseMean.ToString().ToLower(), lanes=(@Model.InputVectorLaneCount,@Model.ScaleVectorLaneCount,@Model.BiasVectorLaneCount,@Model.OutputVectorLaneCount)
@@triton.jit
@($"def {Model.FunctionName}(data, rdata, thread_local_rdata, warp_local_rdata, block_local_rdata{PyNTTTemplateUtility.RuntimeParameterSuffix(Model.RuntimeShapeArgs)}):")
    shard_index = tl.program_id(0).to(tl.int64)
    input0 = @Html.Raw(Model.Input.Expression)
    scale0 = @Html.Raw(Model.Scale.Expression)
    bias0 = @Html.Raw(Model.Bias.Expression)
    output = @Html.Raw(Model.Output.Expression)
@Html.Raw(body.ToString().TrimEnd())
