@using System.Text
@using Nncase.CodeGen.PyNTT
@model Nncase.CodeGen.PyNTT.PyNTTMatmulTemplateModel
@{
    var lhsShape = PyNTTTemplateUtility.ShapeTuple(Model.LhsShape);
    var rhsShape = PyNTTTemplateUtility.ShapeTuple(Model.RhsShape);
    var outputShape = PyNTTTemplateUtility.ShapeTuple(Model.OutputShape);
    static PyNTTDimExpression MultiplyDim(PyNTTDimExpression dim, int lane)
    {
        if (lane == 1)
        {
            return dim;
        }

        var fixedValue = dim.FixedValue.HasValue ? checked(dim.FixedValue.Value * lane) : (long?)null;
        return new($"({dim.PythonExpression} * {lane})", $"({dim.TritonExpression} * {lane})", fixedValue);
    }

    var logicalOutputShape = Model.OutputShape.ToArray();
    logicalOutputShape[^1] = MultiplyDim(logicalOutputShape[^1], Model.OutputNVectorLaneCount);
    var logicalOutputStrides = Model.OutputStrides.ToArray();
    if (Model.OutputNVectorLaneCount > 1)
    {
        logicalOutputStrides[^1] = PyNTTDimExpression.One;
    }

    var m = logicalOutputShape[^2];
    var n = logicalOutputShape[^1];
    var k = Model.TransposeA ? Model.LhsShape[^2] : Model.LhsShape[^1];
    var outputBatchRank = logicalOutputShape.Length - 2;

    static string Indent(int level) => new(' ', level * 4);

    var blockAxis = PyNTTTemplateUtility.SelectBlockAxis(logicalOutputShape, logicalOutputStrides);
    var blockExtent = logicalOutputShape[blockAxis];
    var loopAxes = Enumerable.Range(0, logicalOutputShape.Length).Where(axis => axis != blockAxis).ToArray();

    string AxisIndex(int axis) => axis == blockAxis ? "lane" : $"idx{axis}";
    var row = AxisIndex(logicalOutputShape.Length - 2);
    var col = AxisIndex(logicalOutputShape.Length - 1);

    string BatchOffsetExpression(PyNTTDimExpression[] operandShape, PyNTTDimExpression[] operandStrides)
    {
        var operandBatchRank = operandShape.Length - 2;
        var axisOffset = outputBatchRank - operandBatchRank;
        var terms = new List<string>();
        for (var operandAxis = 0; operandAxis < operandBatchRank; operandAxis++)
        {
            if (operandShape[operandAxis].IsFixedOne)
            {
                continue;
            }

            var outputAxis = axisOffset + operandAxis;
            terms.Add($"{AxisIndex(outputAxis)} * {operandStrides[operandAxis]}");
        }

        return terms.Count == 0 ? "lane * 0" : $"lane * 0 + {string.Join(" + ", terms)}";
    }

    string OutputOffsetExpression()
    {
        var terms = new List<string>();
        for (var axis = 0; axis < Model.OutputShape.Length; axis++)
        {
            var index = axis == Model.OutputShape.Length - 1 && Model.OutputNVectorLaneCount > 1
                ? $"(({AxisIndex(axis)}) // {Model.OutputNVectorLaneCount})"
                : AxisIndex(axis);
            terms.Add($"{index} * {Model.OutputStrides[axis]}");
        }

        var physicalIndex = terms.Count == 0 ? "lane * 0" : $"lane * 0 + {string.Join(" + ", terms)}";
        if (Model.OutputNVectorLaneCount == 1)
        {
            return physicalIndex;
        }

        var outputLaneIndex = $"(({col}) % {Model.OutputNVectorLaneCount})";
        return $"(({physicalIndex}) * {Model.OutputNVectorLaneCount} + {outputLaneIndex})";
    }

    var lhsBatchOffset = BatchOffsetExpression(Model.LhsShape, Model.LhsStrides);
    var rhsBatchOffset = BatchOffsetExpression(Model.RhsShape, Model.RhsStrides);
    var lhsIndex = Model.TransposeA
        ? $"{lhsBatchOffset} + k_index * {Model.LhsStrides[^2]} + {row} * {Model.LhsStrides[^1]}"
        : $"{lhsBatchOffset} + {row} * {Model.LhsStrides[^2]} + k_index * {Model.LhsStrides[^1]}";
    var rhsNIndex = Model.RhsNVectorLaneCount == 1
        ? col
        : $"(({col}) // {Model.RhsNVectorLaneCount})";
    var rhsLaneIndex = Model.RhsNVectorLaneCount == 1
        ? "0"
        : $"(({col}) % {Model.RhsNVectorLaneCount})";
    var rhsIndex = Model.TransposeB
        ? $"{rhsBatchOffset} + {rhsNIndex} * {Model.RhsStrides[^2]} + k_index * {Model.RhsStrides[^1]}"
        : $"{rhsBatchOffset} + k_index * {Model.RhsStrides[^2]} + {rhsNIndex} * {Model.RhsStrides[^1]}";
    var rhsScalarIndex = Model.RhsNVectorLaneCount == 1
        ? rhsIndex
        : $"(({rhsIndex}) * {Model.RhsNVectorLaneCount} + {rhsLaneIndex})";
    var outputIndex = OutputOffsetExpression();

    var body = new StringBuilder();
    var indent = 1;
    foreach (var axis in loopAxes)
    {
        body.AppendLine($"{Indent(indent)}for idx{axis} in tl.range(0, {Model.OutputShape[axis]}):");
        indent++;
    }

    body.AppendLine($"{Indent(indent)}for axis_start in tl.range(0, {blockExtent}, block_size):");
    body.AppendLine($"{Indent(indent + 1)}lane = axis_start + tl.arange(0, block_size)");
    body.AppendLine($"{Indent(indent + 1)}mask = lane < {blockExtent}");
    body.AppendLine($"{Indent(indent + 1)}acc = tl.full((block_size,), 0.0, tl.float32)");
    body.AppendLine($"{Indent(indent + 1)}for k_index in tl.range(0, {k}):");
    body.AppendLine($"{Indent(indent + 2)}lhs_value = tl.load(lhs + lane * 0 + {lhsIndex}, mask=mask, other=0.0)");
    body.AppendLine($"{Indent(indent + 2)}rhs_value = tl.load(rhs + lane * 0 + {rhsScalarIndex}, mask=mask, other=0.0)");
    body.AppendLine($"{Indent(indent + 2)}acc += lhs_value * rhs_value");
    body.AppendLine($"{Indent(indent + 1)}result = acc * {Model.Scale}");
    body.AppendLine($"{Indent(indent + 1)}tl.store(output + {outputIndex}, result, mask=mask)");

    foreach (var axis in loopAxes.Reverse())
    {
        indent--;
    }
}
# generated from CodeGen/PyNTT/Templates/Triton/Kernels/Matmul.py.cshtml
# @Model.Comment; lhs_dtype=@Model.LhsDType, rhs_dtype=@Model.RhsDType, output_dtype=@Model.OutputDType, lhs_shape=@lhsShape, rhs_shape=@rhsShape, output_shape=@outputShape, rhs_n_lane=@Model.RhsNVectorLaneCount, output_n_lane=@Model.OutputNVectorLaneCount
@@triton.jit
@($"def {Model.FunctionName}(data, rdata, thread_local_rdata, warp_local_rdata, block_local_rdata{PyNTTTemplateUtility.RuntimeParameterSuffix(Model.RuntimeShapeArgs)}):")
    shard_index = tl.program_id(0).to(tl.int64)
    lhs = @Html.Raw(Model.Lhs.Expression)
    rhs = @Html.Raw(Model.Rhs.Expression)
    output = @Html.Raw(Model.Output.Expression)
@Html.Raw(body.ToString().TrimEnd())
