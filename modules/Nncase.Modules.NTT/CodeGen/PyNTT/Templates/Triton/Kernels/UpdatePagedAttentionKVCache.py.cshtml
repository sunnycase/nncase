@using System.Text
@using Nncase.CodeGen.PyNTT
@model Nncase.CodeGen.PyNTT.PyNTTUpdatePagedAttentionKVCacheTemplateModel
@{
    var slotsShape = PyNTTTemplateUtility.ShapeTuple(Model.SlotsShape);
    var slotsGlobalShape = PyNTTTemplateUtility.ShapeTuple(Model.SlotsGlobalShape);

    static string Indent(int level) => new(' ', level * 4);

    static string Product(IEnumerable<string> values)
    {
        var array = values.ToArray();
        return array.Length == 0 ? "1" : string.Join(" * ", array.Select(value => $"({value})"));
    }

    string SplitLinearExpression(IReadOnlyList<int> splitAxes, string coordPrefix)
    {
        if (splitAxes.Count == 0)
        {
            return "0";
        }

        var terms = new List<string>();
        for (var i = 0; i < splitAxes.Count; i++)
        {
            var placementAxis = splitAxes[i];
            var stride = splitAxes.Skip(i + 1).Aggregate(1, (acc, axis) => acc * Model.Hierarchy[axis]);
            terms.Add(stride == 1 ? $"{coordPrefix}{placementAxis}" : $"{coordPrefix}{placementAxis} * {stride}");
        }

        return string.Join(" + ", terms);
    }

    string SlotOffset()
    {
        var terms = new List<string>();
        for (var axis = 0; axis < Model.SlotsStrides.Length; axis++)
        {
            terms.Add($"source_idx{axis} * {Model.SlotsStrides[axis]}");
        }

        var elementOffset = terms.Count == 0 ? "linear * 0" : string.Join(" + ", terms);
        return Model.Cache.LaneCount == 1
            ? elementOffset
            : $"(({elementOffset}) * {Model.Cache.LaneCount} + lane_id)";
    }

    string GlobalIndexName(int axis)
    {
        if (axis == Model.SeqAxis)
        {
            return "token_id";
        }

        if (axis == Model.HeadAxis)
        {
            return "head_id";
        }

        if (axis == Model.DimAxis)
        {
            return "dim_block";
        }

        return $"global_idx{axis}";
    }

    var totalElements = Product(new[]
    {
        "num_tokens",
        Model.SlotsGlobalShape[Model.HeadAxis].ToString(),
        Model.SlotsGlobalShape[Model.DimAxis].ToString(),
        Model.Cache.LaneCount.ToString(System.Globalization.CultureInfo.InvariantCulture),
    });
    var blockIndex = Model.Cache.IdLength > 1 ? "(topology_id * num_blocks_per_shard + block_id)" : "block_id";
    var cacheOffset = $"(((((({blockIndex} * {Model.Cache.NumLayers} + {Model.LayerId}) * 2 + {Model.CacheKind}) * {Model.Cache.NumKVHeads} + cache_head_id) * {Model.Cache.HeadDimBlocks} + dim_block) * {Model.Cache.BlockSize} + block_offset) * {Model.Cache.LaneCount} + lane_id)";
    var headSplitAxes = Model.SlotsSplitAxes[Model.HeadAxis];
    var topologyMatchAxes = Model.Cache.NumBlocksSplitAxes.Where(axis => !headSplitAxes.Contains(axis)).ToArray();
    var fullSourceShardIndex = SplitLinearExpression(Enumerable.Range(0, Model.Hierarchy.Length).ToArray(), "source_shard_coord");

    var body = new StringBuilder();
    var indent = 1;

    body.AppendLine($"{Indent(indent)}tmp_shard = shard_index");
    for (var axis = Model.Hierarchy.Length - 1; axis >= 0; axis--)
    {
        body.AppendLine($"{Indent(indent)}shard_coord{axis} = tmp_shard % {Model.Hierarchy[axis]}");
        body.AppendLine($"{Indent(indent)}tmp_shard = tmp_shard // {Model.Hierarchy[axis]}");
    }

    body.AppendLine($"{Indent(indent)}num_seqs = tl.load(cache_meta + 0).to(tl.int64)");
    body.AppendLine($"{Indent(indent)}num_tokens = tl.full((), 0, tl.int64)");
    body.AppendLine($"{Indent(indent)}for seq_id in tl.range(0, num_seqs):");
    body.AppendLine($"{Indent(indent + 1)}context_len = tl.load(cache_meta + 1 + seq_id * 2)");
    body.AppendLine($"{Indent(indent + 1)}seq_len = tl.load(cache_meta + 2 + seq_id * 2)");
    body.AppendLine($"{Indent(indent + 1)}num_tokens += seq_len - context_len");
    body.AppendLine();
    body.AppendLine($"{Indent(indent)}for linear_start in tl.range(0, {totalElements}, block_size):");
    indent++;
    body.AppendLine($"{Indent(indent)}linear = linear_start + tl.arange(0, block_size)");
    body.AppendLine($"{Indent(indent)}mask = linear < {totalElements}");
    body.AppendLine($"{Indent(indent)}lane_id = linear % {Model.Cache.LaneCount}");
    body.AppendLine($"{Indent(indent)}tmp = linear // {Model.Cache.LaneCount}");
    body.AppendLine($"{Indent(indent)}dim_block = tmp % {Model.SlotsGlobalShape[Model.DimAxis]}");
    body.AppendLine($"{Indent(indent)}tmp = tmp // {Model.SlotsGlobalShape[Model.DimAxis]}");
    body.AppendLine($"{Indent(indent)}head_id = tmp % {Model.SlotsGlobalShape[Model.HeadAxis]}");
    body.AppendLine($"{Indent(indent)}token_id = tmp // {Model.SlotsGlobalShape[Model.HeadAxis]}");
    body.AppendLine($"{Indent(indent)}cache_head_id = head_id");
    body.AppendLine($"{Indent(indent)}active = mask & (token_id < num_tokens) & (cache_head_id < {Model.Cache.NumKVHeads})");

    for (var axis = 0; axis < Model.SlotsGlobalShape.Length; axis++)
    {
        var globalIndex = GlobalIndexName(axis);
        body.AppendLine($"{Indent(indent)}active = active & ({globalIndex} < {Model.SlotsGlobalShape[axis]})");
    }

    for (var axis = 0; axis < Model.Hierarchy.Length; axis++)
    {
        body.AppendLine($"{Indent(indent)}source_shard_coord{axis} = shard_coord{axis}");
    }

    for (var axis = 0; axis < Model.SlotsGlobalShape.Length; axis++)
    {
        var splitAxes = Model.SlotsSplitAxes[axis];
        var globalIndex = GlobalIndexName(axis);
        if (splitAxes.Length == 0)
        {
            body.AppendLine($"{Indent(indent)}source_idx{axis} = {globalIndex}");
        }
        else
        {
            var divisor = splitAxes.Aggregate(1, (acc, placementAxis) => acc * Model.Hierarchy[placementAxis]);
            body.AppendLine($"{Indent(indent)}source_local_dim{axis} = tl.cdiv({Model.SlotsGlobalShape[axis]}, {divisor})");
            body.AppendLine($"{Indent(indent)}source_split_linear{axis} = {globalIndex} // source_local_dim{axis}");
            body.AppendLine($"{Indent(indent)}source_idx{axis} = {globalIndex} - source_split_linear{axis} * source_local_dim{axis}");
            body.AppendLine($"{Indent(indent)}tmp_source_split{axis} = source_split_linear{axis}");
            for (var i = splitAxes.Length - 1; i >= 0; i--)
            {
                var placementAxis = splitAxes[i];
                body.AppendLine($"{Indent(indent)}source_shard_coord{placementAxis} = tmp_source_split{axis} % {Model.Hierarchy[placementAxis]}");
                body.AppendLine($"{Indent(indent)}tmp_source_split{axis} = tmp_source_split{axis} // {Model.Hierarchy[placementAxis]}");
            }
        }
    }

    foreach (var axis in headSplitAxes)
    {
        body.AppendLine($"{Indent(indent)}active = active & (source_shard_coord{axis} == shard_coord{axis})");
    }

    if (Model.Cache.IdLength > 1)
    {
        body.AppendLine($"{Indent(indent)}topology_id = tl.load(slot_mapping + token_id * {Model.Cache.IdLength}, mask=active, other=0)");
        body.AppendLine($"{Indent(indent)}tmp_topology = topology_id");
        for (var i = Model.Cache.NumBlocksSplitAxes.Length - 1; i >= 0; i--)
        {
            var axis = Model.Cache.NumBlocksSplitAxes[i];
            body.AppendLine($"{Indent(indent)}topology_coord{axis} = tmp_topology % {Model.Hierarchy[axis]}");
            body.AppendLine($"{Indent(indent)}tmp_topology = tmp_topology // {Model.Hierarchy[axis]}");
        }

        foreach (var axis in topologyMatchAxes)
        {
            body.AppendLine($"{Indent(indent)}active = active & (topology_coord{axis} == shard_coord{axis})");
        }
    }

    body.AppendLine($"{Indent(indent)}slot_id = tl.load(slot_mapping + token_id * {Model.Cache.IdLength} + {Model.Cache.IdLength - 1}, mask=active, other=0)");
    body.AppendLine($"{Indent(indent)}block_id = slot_id // {Model.Cache.BlockSize}");
    body.AppendLine($"{Indent(indent)}block_offset = slot_id % {Model.Cache.BlockSize}");
    body.AppendLine($"{Indent(indent)}source_shard_index = {fullSourceShardIndex}");
    body.AppendLine($"{Indent(indent)}slot_offsets = {SlotOffset()}");
    body.AppendLine($"{Indent(indent)}source_byte_offsets = source_shard_index * {Model.SlotsPoolBytes} + {Model.SlotsOffsetBytes} + slot_offsets * {Model.ScalarElementSizeBytes}");
    body.AppendLine($"{Indent(indent)}cache_offsets = {cacheOffset}");
    body.AppendLine($"{Indent(indent)}value = tl.load(({Model.SlotsBaseName} + source_byte_offsets).to(tl.pointer_type({Model.SlotsTritonDType})), mask=active, other=0.0)");
    body.AppendLine($"{Indent(indent)}tl.store(kv_cache + cache_offsets, value, mask=active)");
}
# generated from CodeGen/PyNTT/Templates/Triton/Kernels/UpdatePagedAttentionKVCache.py.cshtml
# @Model.Comment; dtype=@Model.SlotsDType, slots_shape=@slotsShape, slots_global_shape=@slotsGlobalShape, layer=@Model.LayerId, cache_kind=@Model.CacheKind
@@triton.jit
@($"def {Model.FunctionName}(slot_mapping, kv_cache, num_blocks_per_shard, cache_meta, data, rdata, thread_local_rdata, warp_local_rdata, block_local_rdata{PyNTTTemplateUtility.RuntimeParameterSuffix(Model.RuntimeShapeArgs)}):")
    shard_index = tl.program_id(0).to(tl.int64)
@Html.Raw(body.ToString().TrimEnd())
