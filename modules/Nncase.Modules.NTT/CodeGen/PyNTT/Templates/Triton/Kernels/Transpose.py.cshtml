@using System.Text
@using Nncase.CodeGen.PyNTT
@model Nncase.CodeGen.PyNTT.PyNTTTransposeTemplateModel
@{
    var inputShape = PyNTTTemplateUtility.ShapeTuple(Model.InputShape);
    var outputShape = PyNTTTemplateUtility.ShapeTuple(Model.OutputShape);
    var perm = "(" + string.Join(", ", Model.Perm) + (Model.Perm.Length == 1 ? "," : string.Empty) + ")";
    var totalElements = Multiply(ProductExpression(Model.OutputShape), Model.OutputVectorLaneCount.ToString(System.Globalization.CultureInfo.InvariantCulture));

    static string Indent(int level) => new(' ', level * 4);

    static string ProductExpression(IReadOnlyList<PyNTTDimExpression> values)
    {
        if (values.Count == 0)
        {
            return "1";
        }

        return string.Join(" * ", values.Select(value => $"({value.TritonExpression})"));
    }

    static string Multiply(string lhs, string rhs)
    {
        return rhs == "1" ? lhs : $"({lhs}) * {rhs}";
    }

    static string TensorOffset(string prefix, IReadOnlyList<PyNTTDimExpression> strides, int laneCount, string laneFlat)
    {
        var terms = new List<string>();
        for (var axis = 0; axis < strides.Count; axis++)
        {
            terms.Add($"{prefix}{axis} * {strides[axis]}");
        }

        var tensorOffset = terms.Count == 0 ? "lane_flat * 0" : string.Join(" + ", terms);
        return laneCount == 1 ? tensorOffset : $"(({tensorOffset}) * {laneCount} + {laneFlat})";
    }

    void AppendTensorIndexDecompose(StringBuilder builder, int indent, string linearName, string prefix, IReadOnlyList<PyNTTDimExpression> shape)
    {
        builder.AppendLine($"{Indent(indent)}tmp = {linearName}");
        for (var axis = shape.Count - 1; axis >= 0; axis--)
        {
            builder.AppendLine($"{Indent(indent)}{prefix}{axis} = tmp % {shape[axis]}");
            builder.AppendLine($"{Indent(indent)}tmp = tmp // {shape[axis]}");
        }
    }

    var body = new StringBuilder();
    body.AppendLine($"    for linear_start in tl.range(0, {totalElements}, block_size):");
    body.AppendLine("        linear = linear_start + tl.arange(0, block_size)");
    body.AppendLine($"        mask = linear < {totalElements}");
    body.AppendLine($"        lane_flat = linear % {Model.OutputVectorLaneCount}");
    body.AppendLine($"        output_tensor_linear = linear // {Model.OutputVectorLaneCount}");
    AppendTensorIndexDecompose(body, 2, "output_tensor_linear", "out_idx", Model.OutputShape);
    for (var inputAxis = 0; inputAxis < Model.InputShape.Length; inputAxis++)
    {
        var outputAxis = Array.IndexOf(Model.Perm, inputAxis);
        body.AppendLine($"        in_idx{inputAxis} = out_idx{outputAxis}");
    }

    body.AppendLine($"        input_offsets = {TensorOffset("in_idx", Model.InputStrides, Model.InputVectorLaneCount, "lane_flat")}");
    body.AppendLine($"        output_offsets = {TensorOffset("out_idx", Model.OutputStrides, Model.OutputVectorLaneCount, "lane_flat")}");
    body.AppendLine("        value = tl.load(input + input_offsets, mask=mask)");
    body.AppendLine("        tl.store(output + output_offsets, value, mask=mask)");
}
# generated from CodeGen/PyNTT/Templates/Triton/Kernels/Transpose.py.cshtml
# @Model.Comment; input_dtype=@Model.InputDType, output_dtype=@Model.OutputDType, input_shape=@inputShape, output_shape=@outputShape, perm=@perm
@@triton.jit
@($"def {Model.FunctionName}(data, rdata, thread_local_rdata, warp_local_rdata, block_local_rdata{PyNTTTemplateUtility.RuntimeParameterSuffix(Model.RuntimeShapeArgs)}):")
    shard_index = tl.program_id(0).to(tl.int64)
    input = @Html.Raw(Model.Input.Expression)
    output = @Html.Raw(Model.Output.Expression)
@Html.Raw(body.ToString().TrimEnd())
