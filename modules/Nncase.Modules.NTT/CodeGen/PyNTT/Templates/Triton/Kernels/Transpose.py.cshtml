@using System.Text
@model Nncase.CodeGen.PyNTT.PyNTTTransposeTemplateModel
@{
    var inputShape = "(" + string.Join(", ", Model.InputShape) + (Model.InputShape.Length == 1 ? "," : string.Empty) + ")";
    var outputShape = "(" + string.Join(", ", Model.OutputShape) + (Model.OutputShape.Length == 1 ? "," : string.Empty) + ")";
    var perm = "(" + string.Join(", ", Model.Perm) + (Model.Perm.Length == 1 ? "," : string.Empty) + ")";

    static string Indent(int level) => new(' ', level * 4);

    static int SelectBlockAxis(long[] shape, long[] strides)
    {
        if (shape.Length == 0)
        {
            return 0;
        }

        for (var i = shape.Length - 1; i >= 0; i--)
        {
            if (shape[i] > 1 && strides[i] == 1)
            {
                return i;
            }
        }

        for (var i = shape.Length - 1; i >= 0; i--)
        {
            if (shape[i] > 1)
            {
                return i;
            }
        }

        return shape.Length - 1;
    }

    var blockAxis = SelectBlockAxis(Model.OutputShape, Model.OutputStrides);
    var blockExtent = Model.OutputShape.Length == 0 ? 1 : Model.OutputShape[blockAxis];
    var loopAxes = Enumerable.Range(0, Model.OutputShape.Length).Where(axis => axis != blockAxis).ToArray();

    string AxisIndex(int outputAxis) => outputAxis == blockAxis ? "lane" : $"idx{outputAxis}";

    string OutputOffsetExpression()
    {
        var terms = new List<string>();
        for (var outputAxis = 0; outputAxis < Model.OutputShape.Length; outputAxis++)
        {
            terms.Add($"{AxisIndex(outputAxis)} * {Model.OutputStrides[outputAxis]}");
        }

        return terms.Count == 0 ? "lane * 0" : $"lane * 0 + {string.Join(" + ", terms)}";
    }

    string InputOffsetExpression()
    {
        var terms = new List<string>();
        for (var inputAxis = 0; inputAxis < Model.InputShape.Length; inputAxis++)
        {
            var outputAxis = Array.IndexOf(Model.Perm, inputAxis);
            terms.Add($"{AxisIndex(outputAxis)} * {Model.InputStrides[inputAxis]}");
        }

        return terms.Count == 0 ? "lane * 0" : $"lane * 0 + {string.Join(" + ", terms)}";
    }

    var body = new StringBuilder();
    var indent = 1;
    foreach (var axis in loopAxes)
    {
        body.AppendLine($"{Indent(indent)}idx{axis} = 0");
        body.AppendLine($"{Indent(indent)}while idx{axis} < {Model.OutputShape[axis]}:");
        indent++;
    }

    body.AppendLine($"{Indent(indent)}axis_start = 0");
    body.AppendLine($"{Indent(indent)}while axis_start < {blockExtent}:");
    body.AppendLine($"{Indent(indent + 1)}lane = axis_start + tl.arange(0, block_size)");
    body.AppendLine($"{Indent(indent + 1)}mask = lane < {blockExtent}");
    body.AppendLine($"{Indent(indent + 1)}input_offsets = {InputOffsetExpression()}");
    body.AppendLine($"{Indent(indent + 1)}output_offsets = {OutputOffsetExpression()}");
    body.AppendLine($"{Indent(indent + 1)}value = tl.load(input + input_offsets, mask=mask)");
    body.AppendLine($"{Indent(indent + 1)}tl.store(output + output_offsets, value, mask=mask)");
    body.AppendLine($"{Indent(indent + 1)}axis_start += block_size");

    foreach (var axis in loopAxes.Reverse())
    {
        body.AppendLine($"{Indent(indent)}idx{axis} += 1");
        indent--;
    }
}
# generated from CodeGen/PyNTT/Templates/Triton/Kernels/Transpose.py.cshtml
# @Model.Comment; input_dtype=@Model.InputDType, output_dtype=@Model.OutputDType, input_shape=@inputShape, output_shape=@outputShape, perm=@perm
@@triton.jit
@($"def {Model.FunctionName}(data, rdata, thread_local_rdata, warp_local_rdata, block_local_rdata, block_size: tl.constexpr):")
    shard_index = tl.program_id(0)
    input = @Html.Raw(Model.Input.Expression)
    output = @Html.Raw(Model.Output.Expression)
@Html.Raw(body.ToString().TrimEnd())
