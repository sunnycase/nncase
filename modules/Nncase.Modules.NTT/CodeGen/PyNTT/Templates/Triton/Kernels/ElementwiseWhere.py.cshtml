@using System.Text
@using Nncase.CodeGen.PyNTT
@model Nncase.CodeGen.PyNTT.PyNTTElementwiseWhereTemplateModel
@{
    var shape = PyNTTTemplateUtility.ShapeTuple(Model.Shape);

    static string Indent(int level) => new(' ', level * 4);
    static PyNTTDimExpression MultiplyDim(PyNTTDimExpression dim, int lane)
    {
        if (lane == 1)
        {
            return dim;
        }

        var fixedValue = dim.FixedValue.HasValue ? checked(dim.FixedValue.Value * lane) : (long?)null;
        return new($"({dim.PythonExpression} * {lane})", $"({dim.TritonExpression} * {lane})", fixedValue);
    }

    static PyNTTDimExpression[] LogicalShape(PyNTTDimExpression[] physicalShape, int laneCount)
    {
        var logicalShape = physicalShape.ToArray();
        if (laneCount > 1)
        {
            logicalShape[^1] = MultiplyDim(logicalShape[^1], laneCount);
        }

        return logicalShape;
    }

    static PyNTTDimExpression[] LogicalStrides(PyNTTDimExpression[] physicalStrides, int laneCount)
    {
        var logicalStrides = physicalStrides.ToArray();
        if (laneCount > 1)
        {
            logicalStrides[^1] = PyNTTDimExpression.One;
        }

        return logicalStrides;
    }

    var logicalCondShape = LogicalShape(Model.CondShape, Model.CondVectorLaneCount);
    var logicalTrueShape = LogicalShape(Model.TrueShape, Model.TrueVectorLaneCount);
    var logicalFalseShape = LogicalShape(Model.FalseShape, Model.FalseVectorLaneCount);
    var logicalOutputShape = LogicalShape(Model.OutputShape, Model.OutputVectorLaneCount);
    var logicalOutputStrides = LogicalStrides(Model.OutputStrides, Model.OutputVectorLaneCount);
    var rank = logicalOutputShape.Length;

    var blockAxis = PyNTTTemplateUtility.SelectBlockAxis(logicalOutputShape, logicalOutputStrides);
    var blockExtent = rank == 0 ? PyNTTDimExpression.One : logicalOutputShape[blockAxis];
    var loopAxes = Enumerable.Range(0, rank).Where(axis => axis != blockAxis).ToArray();

    string AxisIndex(int axis) => axis == blockAxis ? "lane" : $"idx{axis}";

    string OffsetExpression(PyNTTDimExpression[] physicalShape, PyNTTDimExpression[] logicalShape, PyNTTDimExpression[] operandStrides, int laneCount)
    {
        var axisOffset = rank - logicalShape.Length;
        var terms = new List<string>();
        for (var i = 0; i < logicalShape.Length; i++)
        {
            if (logicalShape[i].IsFixedOne)
            {
                continue;
            }

            var outputAxis = axisOffset + i;
            var index = AxisIndex(outputAxis);
            if (laneCount > 1 && i == physicalShape.Length - 1)
            {
                index = $"(({index}) // {laneCount})";
            }

            terms.Add($"{index} * {operandStrides[i]}");
        }

        var physicalIndex = terms.Count == 0 ? "lane * 0" : $"lane * 0 + {string.Join(" + ", terms)}";
        if (laneCount == 1)
        {
            return physicalIndex;
        }

        var logicalLastAxis = axisOffset + logicalShape.Length - 1;
        var laneIndex = $"(({AxisIndex(logicalLastAxis)}) % {laneCount})";
        return $"(({physicalIndex}) * {laneCount} + {laneIndex})";
    }

    var body = new StringBuilder();
    var indent = 1;
    foreach (var axis in loopAxes)
    {
        body.AppendLine($"{Indent(indent)}for idx{axis} in tl.range(0, {logicalOutputShape[axis]}):");
        indent++;
    }

    body.AppendLine($"{Indent(indent)}for axis_start in tl.range(0, {blockExtent}, block_size):");
    body.AppendLine($"{Indent(indent + 1)}lane = axis_start + tl.arange(0, block_size)");
    body.AppendLine($"{Indent(indent + 1)}mask = lane < {blockExtent}");
    body.AppendLine($"{Indent(indent + 1)}cond_offsets = {OffsetExpression(Model.CondShape, logicalCondShape, Model.CondStrides, Model.CondVectorLaneCount)}");
    body.AppendLine($"{Indent(indent + 1)}true_offsets = {OffsetExpression(Model.TrueShape, logicalTrueShape, Model.TrueStrides, Model.TrueVectorLaneCount)}");
    body.AppendLine($"{Indent(indent + 1)}false_offsets = {OffsetExpression(Model.FalseShape, logicalFalseShape, Model.FalseStrides, Model.FalseVectorLaneCount)}");
    body.AppendLine($"{Indent(indent + 1)}output_offsets = {OffsetExpression(Model.OutputShape, logicalOutputShape, Model.OutputStrides, Model.OutputVectorLaneCount)}");
    body.AppendLine($"{Indent(indent + 1)}predicate = tl.load(cond + cond_offsets, mask=mask)");
    body.AppendLine($"{Indent(indent + 1)}value0 = tl.load(true_value + true_offsets, mask=mask)");
    body.AppendLine($"{Indent(indent + 1)}value1 = tl.load(false_value + false_offsets, mask=mask)");
    body.AppendLine($"{Indent(indent + 1)}result = tl.where(predicate, value0, value1)");
    body.AppendLine($"{Indent(indent + 1)}tl.store(output + output_offsets, result, mask=mask)");

    foreach (var axis in loopAxes.Reverse())
    {
        indent--;
    }
}
