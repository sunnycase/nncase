@using System.Text
@using Nncase.CodeGen.PyNTT
@model Nncase.CodeGen.PyNTT.PyNTTVectorLayoutTemplateModel
@{
    var inputShape = PyNTTTemplateUtility.ShapeTuple(Model.InputShape);
    var outputShape = PyNTTTemplateUtility.ShapeTuple(Model.OutputShape);
    var op = Model.IsPack ? "pack" : "unpack";
    var inputLaneCount = Product(Model.InputLanes);
    var outputLaneCount = Product(Model.OutputLanes);
    var domainShape = Model.IsPack ? Model.OutputShape : Model.InputShape;
    var domainLaneCount = Model.IsPack ? outputLaneCount : inputLaneCount;
    var totalElements = Multiply(ProductExpression(domainShape), domainLaneCount.ToString(System.Globalization.CultureInfo.InvariantCulture));

    static string Indent(int level) => new(' ', level * 4);

    static long Product(IReadOnlyList<int> values)
    {
        var product = 1L;
        foreach (var value in values)
        {
            product *= value;
        }

        return product;
    }

    static string ProductExpression(IReadOnlyList<PyNTTDimExpression> values)
    {
        if (values.Count == 0)
        {
            return "1";
        }

        return string.Join(" * ", values.Select(value => $"({value.TritonExpression})"));
    }

    static string Multiply(string lhs, string rhs)
    {
        return rhs == "1" ? lhs : $"({lhs}) * {rhs}";
    }

    static string LaneAt(string laneGroup, IReadOnlyList<int> lanes, int index)
    {
        var stride = Product(lanes.Skip(index + 1).ToArray());
        return stride == 1
            ? $"({laneGroup}) % {lanes[index]}"
            : $"(({laneGroup}) // {stride}) % {lanes[index]}";
    }

    static string TensorOffset(string prefix, IReadOnlyList<PyNTTDimExpression> strides, long laneCount, string laneFlat)
    {
        var terms = new List<string>();
        for (var axis = 0; axis < strides.Count; axis++)
        {
            terms.Add($"{prefix}{axis} * {strides[axis]}");
        }

        var tensorOffset = terms.Count == 0 ? "lane_flat * 0" : string.Join(" + ", terms);
        return laneCount == 1 ? tensorOffset : $"(({tensorOffset}) * {laneCount} + {laneFlat})";
    }

    void AppendTensorIndexDecompose(StringBuilder builder, int indent, string linearName, string prefix, IReadOnlyList<PyNTTDimExpression> shape)
    {
        builder.AppendLine($"{Indent(indent)}tmp = {linearName}");
        for (var axis = shape.Count - 1; axis >= 0; axis--)
        {
            builder.AppendLine($"{Indent(indent)}{prefix}{axis} = tmp % {shape[axis]}");
            builder.AppendLine($"{Indent(indent)}tmp = tmp // {shape[axis]}");
        }
    }

    var body = new StringBuilder();
    body.AppendLine($"    for linear_start in tl.range(0, {totalElements}, block_size):");
    body.AppendLine("        linear = linear_start + tl.arange(0, block_size)");
    body.AppendLine($"        mask = linear < {totalElements}");
    body.AppendLine($"        lane_flat = linear % {domainLaneCount}");
    body.AppendLine($"        tensor_linear = linear // {domainLaneCount}");

    if (Model.IsPack)
    {
        AppendTensorIndexDecompose(body, 2, "tensor_linear", "out_idx", Model.OutputShape);
        var inputLaneFlat = inputLaneCount == 1 ? "lane_flat * 0" : $"lane_flat % {inputLaneCount}";
        var packLaneGroup = inputLaneCount == 1 ? "lane_flat" : $"lane_flat // {inputLaneCount}";
        body.AppendLine($"        input_lane_flat = {inputLaneFlat}");
        body.AppendLine($"        new_lane_group = {packLaneGroup}");
        body.AppendLine("        valid = mask");
        for (var axis = 0; axis < Model.InputShape.Length; axis++)
        {
            var packedAxis = Array.IndexOf(Model.Axes, axis);
            if (packedAxis >= 0)
            {
                var laneValue = LaneAt("new_lane_group", Model.Lanes, packedAxis);
                body.AppendLine($"{Indent(2)}lane{packedAxis} = {laneValue}");
                body.AppendLine($"{Indent(2)}in_idx{axis} = out_idx{axis} * {Model.Lanes[packedAxis]} + lane{packedAxis}");
                body.AppendLine($"{Indent(2)}valid = valid & (in_idx{axis} < {Model.InputShape[axis]})");
            }
            else
            {
                body.AppendLine($"{Indent(2)}in_idx{axis} = out_idx{axis}");
            }
        }

        body.AppendLine($"        input_offsets = {TensorOffset("in_idx", Model.InputStrides, inputLaneCount, "input_lane_flat")}");
        body.AppendLine($"        output_offsets = {TensorOffset("out_idx", Model.OutputStrides, outputLaneCount, "lane_flat")}");
        body.AppendLine("        value = tl.load(input_ptr + input_offsets, mask=valid, other=0)");
        body.AppendLine("        tl.store(output_ptr + output_offsets, value, mask=mask)");
    }
    else
    {
        AppendTensorIndexDecompose(body, 2, "tensor_linear", "in_idx", Model.InputShape);
        var outputLaneFlat = outputLaneCount == 1 ? "lane_flat * 0" : $"lane_flat % {outputLaneCount}";
        var unpackLaneGroup = outputLaneCount == 1 ? "lane_flat" : $"lane_flat // {outputLaneCount}";
        body.AppendLine($"        output_lane_flat = {outputLaneFlat}");
        body.AppendLine($"        new_lane_group = {unpackLaneGroup}");
        body.AppendLine("        valid = mask");
        for (var axis = 0; axis < Model.OutputShape.Length; axis++)
        {
            var unpackedAxis = Array.IndexOf(Model.Axes, axis);
            if (unpackedAxis >= 0)
            {
                var laneValue = LaneAt("new_lane_group", Model.Lanes, unpackedAxis);
                body.AppendLine($"{Indent(2)}lane{unpackedAxis} = {laneValue}");
                body.AppendLine($"{Indent(2)}out_idx{axis} = in_idx{axis} * {Model.Lanes[unpackedAxis]} + lane{unpackedAxis}");
                body.AppendLine($"{Indent(2)}valid = valid & (out_idx{axis} < {Model.OutputShape[axis]})");
            }
            else
            {
                body.AppendLine($"{Indent(2)}out_idx{axis} = in_idx{axis}");
            }
        }

        body.AppendLine($"        input_offsets = {TensorOffset("in_idx", Model.InputStrides, inputLaneCount, "lane_flat")}");
        body.AppendLine($"        output_offsets = {TensorOffset("out_idx", Model.OutputStrides, outputLaneCount, "output_lane_flat")}");
        body.AppendLine("        value = tl.load(input_ptr + input_offsets, mask=valid, other=0)");
        body.AppendLine("        tl.store(output_ptr + output_offsets, value, mask=valid)");
    }

    body.AppendLine("        linear_start += block_size");
}
# generated from CodeGen/PyNTT/Templates/Triton/Kernels/VectorLayout.py.cshtml
# @Model.Comment; op=@op, input_dtype=@Model.InputDType, output_dtype=@Model.OutputDType, input_shape=@inputShape, output_shape=@outputShape
@@triton.jit
@($"def {Model.FunctionName}(data, rdata, thread_local_rdata, warp_local_rdata, block_local_rdata{PyNTTTemplateUtility.RuntimeParameterSuffix(Model.RuntimeShapeArgs)}):")
    shard_index = tl.program_id(0).to(tl.int64)
    input_ptr = @Html.Raw(Model.Input.Expression)
    output_ptr = @Html.Raw(Model.Output.Expression)
@Html.Raw(body.ToString().TrimEnd())
