            return localIndex;
        }

        var divisor = splitAxes.Aggregate(1, (acc, placementAxis) => acc * Model.Hierarchy[placementAxis]);
        return $"{localIndex} + ({SplitLinearExpression(splitAxes)}) * tl.cdiv({globalExtent}, {divisor})";
