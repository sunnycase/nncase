@using System.Text
@using Nncase.CodeGen.PyNTT
@model Nncase.CodeGen.PyNTT.PyNTTSummaTemplateModel
@{
    var lhsShape = PyNTTTemplateUtility.ShapeTuple(Model.LhsShape);
    var rhsShape = PyNTTTemplateUtility.ShapeTuple(Model.RhsShape);
    var outputShape = PyNTTTemplateUtility.ShapeTuple(Model.OutputShape);
    var lhsGlobalShape = PyNTTTemplateUtility.ShapeTuple(Model.LhsGlobalShape);
    var rhsGlobalShape = PyNTTTemplateUtility.ShapeTuple(Model.RhsGlobalShape);
    var outputGlobalShape = PyNTTTemplateUtility.ShapeTuple(Model.OutputGlobalShape);

    const int BlockM = 16;
    const int BlockN = 16;
    const int BlockK = 32;

    static string Indent(int level) => new(' ', level * 4);

    static PyNTTDimExpression MultiplyDim(PyNTTDimExpression dim, int lane)
    {
        if (lane == 1)
        {
            return dim;
        }

        var fixedValue = dim.FixedValue.HasValue ? checked(dim.FixedValue.Value * lane) : (long?)null;
        return new($"({dim.PythonExpression} * {lane})", $"({dim.TritonExpression} * {lane})", fixedValue);
    }

    string SplitLinearExpression(IReadOnlyList<int> splitAxes, string coordPrefix)
    {
        if (splitAxes.Count == 0)
        {
            return "0";
        }

        var terms = new List<string>();
        for (var i = 0; i < splitAxes.Count; i++)
        {
            var placementAxis = splitAxes[i];
            var stride = splitAxes.Skip(i + 1).Aggregate(1, (acc, axis) => acc * Model.Hierarchy[axis]);
            terms.Add(stride == 1 ? $"{coordPrefix}{placementAxis}" : $"{coordPrefix}{placementAxis} * {stride}");
        }

        return string.Join(" + ", terms);
    }

    void AppendCurrentShardCoords(StringBuilder body, int indent)
    {
        body.AppendLine($"{Indent(indent)}tmp_shard = shard_index");
        for (var axis = Model.Hierarchy.Length - 1; axis >= 0; axis--)
        {
            body.AppendLine($"{Indent(indent)}shard_coord{axis} = tmp_shard % {Model.Hierarchy[axis]}");
            body.AppendLine($"{Indent(indent)}tmp_shard = tmp_shard // {Model.Hierarchy[axis]}");
        }
    }

    void AppendOutputAxisRange(StringBuilder body, int indent, string prefix, int axis, PyNTTDimExpression globalExtent, int[] splitAxes)
    {
        if (splitAxes.Length == 0)
        {
            body.AppendLine($"{Indent(indent)}{prefix}_local_dim = {globalExtent}");
            body.AppendLine($"{Indent(indent)}{prefix}_global_base = 0");
            body.AppendLine($"{Indent(indent)}{prefix}_iter_dim = {globalExtent}");
            return;
        }

        var divisor = splitAxes.Aggregate(1, (acc, placementAxis) => acc * Model.Hierarchy[placementAxis]);
        body.AppendLine($"{Indent(indent)}{prefix}_local_dim = tl.cdiv({globalExtent}, {divisor})");
        body.AppendLine($"{Indent(indent)}{prefix}_split_linear = {SplitLinearExpression(splitAxes, "shard_coord")}");
        body.AppendLine($"{Indent(indent)}{prefix}_global_base = {prefix}_split_linear * {prefix}_local_dim");
        body.AppendLine($"{Indent(indent)}{prefix}_remaining = {globalExtent} - {prefix}_global_base");
        body.AppendLine($"{Indent(indent)}{prefix}_iter_dim = tl.minimum({prefix}_local_dim, tl.maximum({prefix}_remaining, 0))");
    }

    string LocalIndexExpression(StringBuilder body, int indent, string prefix, string globalIndex, PyNTTDimExpression globalExtent, int[] splitAxes)
    {
        if (splitAxes.Length == 0)
        {
            return globalIndex;
        }

        var divisor = splitAxes.Aggregate(1, (acc, placementAxis) => acc * Model.Hierarchy[placementAxis]);
        body.AppendLine($"{Indent(indent)}{prefix}_local_dim = tl.cdiv({globalExtent}, {divisor})");
        body.AppendLine($"{Indent(indent)}{prefix}_split_linear = ({globalIndex}) // {prefix}_local_dim");
        body.AppendLine($"{Indent(indent)}{prefix}_local = ({globalIndex}) - {prefix}_split_linear * {prefix}_local_dim");
        body.AppendLine($"{Indent(indent)}{prefix}_tmp_split = {prefix}_split_linear");
        for (var i = splitAxes.Length - 1; i >= 0; i--)
        {
            var placementAxis = splitAxes[i];
            body.AppendLine($"{Indent(indent)}source_shard_coord{placementAxis} = {prefix}_tmp_split % {Model.Hierarchy[placementAxis]}");
            body.AppendLine($"{Indent(indent)}{prefix}_tmp_split = {prefix}_tmp_split // {Model.Hierarchy[placementAxis]}");
        }

        return $"{prefix}_local";
    }

    void AppendSourceShardCoords(StringBuilder body, int indent)
    {
        for (var axis = 0; axis < Model.Hierarchy.Length; axis++)
        {
            body.AppendLine($"{Indent(indent)}source_shard_coord{axis} = shard_coord{axis}");
        }
    }

    string SourceShardIndex()
        => SplitLinearExpression(Enumerable.Range(0, Model.Hierarchy.Length).ToArray(), "source_shard_coord");

    string MaybeVectorizedOffset(string physicalOffset, string laneIndex, int vectorLaneCount)
        => vectorLaneCount == 1 ? physicalOffset : $"(({physicalOffset}) * {vectorLaneCount} + {laneIndex})";

    var globalM = Model.OutputGlobalShape[0];
    var globalK = Model.LhsGlobalShape[1];
    var outputGlobalPhysicalN = Model.OutputGlobalShape[1];
    var outputGlobalLogicalN = MultiplyDim(outputGlobalPhysicalN, Model.OutputNVectorLaneCount);
    var rhsGlobalLogicalN = MultiplyDim(Model.RhsGlobalShape[1], Model.RhsNVectorLaneCount);

    var body = new StringBuilder();
    var indent = 1;
    AppendCurrentShardCoords(body, indent);
    AppendOutputAxisRange(body, indent, "out_m", 0, Model.OutputGlobalShape[0], Model.OutputSplitAxes[0]);
    AppendOutputAxisRange(body, indent, "out_n", 1, outputGlobalPhysicalN, Model.OutputSplitAxes[1]);
    body.AppendLine($"{Indent(indent)}out_n_logical_iter_dim = out_n_iter_dim * {Model.OutputNVectorLaneCount}");
    body.AppendLine($"{Indent(indent)}out_n_logical_global_base = out_n_global_base * {Model.OutputNVectorLaneCount}");

    body.AppendLine($"{Indent(indent)}for m_start in tl.range(0, out_m_iter_dim, {BlockM}):");
    body.AppendLine($"{Indent(indent + 1)}offs_m = m_start + tl.arange(0, {BlockM})");
    body.AppendLine($"{Indent(indent + 1)}global_m = out_m_global_base + offs_m");
    body.AppendLine($"{Indent(indent + 1)}for n_start in tl.range(0, out_n_logical_iter_dim, {BlockN}):");
    body.AppendLine($"{Indent(indent + 2)}offs_n = n_start + tl.arange(0, {BlockN})");
    body.AppendLine($"{Indent(indent + 2)}global_n = out_n_logical_global_base + offs_n");
    body.AppendLine($"{Indent(indent + 2)}acc = tl.zeros(({BlockM}, {BlockN}), tl.float32)");
    body.AppendLine($"{Indent(indent + 2)}for k_start in tl.range(0, {globalK}, {BlockK}):");
    body.AppendLine($"{Indent(indent + 3)}global_k = k_start + tl.arange(0, {BlockK})");

    AppendSourceShardCoords(body, indent + 3);
    var lhsM = LocalIndexExpression(body, indent + 3, "lhs_m", "global_m[:, None]", Model.LhsGlobalShape[0], Model.LhsSplitAxes[0]);
    var lhsK = LocalIndexExpression(body, indent + 3, "lhs_k", "global_k[None, :]", Model.LhsGlobalShape[1], Model.LhsSplitAxes[1]);
    body.AppendLine($"{Indent(indent + 3)}lhs_shard_index = {SourceShardIndex()}");
    body.AppendLine($"{Indent(indent + 3)}lhs_offsets = {lhsM} * {Model.LhsStrides[0]} + {lhsK} * {Model.LhsStrides[1]}");
    body.AppendLine($"{Indent(indent + 3)}lhs_ptrs = ({Model.LhsBaseName} + lhs_shard_index * {Model.LhsPoolBytes} + {Model.LhsOffsetBytes}).to(tl.pointer_type({Model.LhsTritonDType}))");
    body.AppendLine($"{Indent(indent + 3)}lhs_mask = (offs_m[:, None] < out_m_iter_dim) & (global_m[:, None] < {globalM}) & (global_k[None, :] < {globalK})");
    body.AppendLine($"{Indent(indent + 3)}lhs_values = tl.load(lhs_ptrs + lhs_offsets, mask=lhs_mask, other=0.0)");

    AppendSourceShardCoords(body, indent + 3);
    body.AppendLine($"{Indent(indent + 3)}rhs_global_n_physical = global_n // {Model.RhsNVectorLaneCount}");
    body.AppendLine($"{Indent(indent + 3)}rhs_lane = global_n * 0");
    if (Model.RhsNVectorLaneCount != 1)
    {
        body.AppendLine($"{Indent(indent + 3)}rhs_lane = global_n % {Model.RhsNVectorLaneCount}");
    }

    var rhsK = LocalIndexExpression(body, indent + 3, "rhs_k", "global_k[:, None]", Model.RhsGlobalShape[0], Model.RhsSplitAxes[0]);
    var rhsN = LocalIndexExpression(body, indent + 3, "rhs_n", "rhs_global_n_physical[None, :]", Model.RhsGlobalShape[1], Model.RhsSplitAxes[1]);
    body.AppendLine($"{Indent(indent + 3)}rhs_shard_index = {SourceShardIndex()}");
    body.AppendLine($"{Indent(indent + 3)}rhs_physical_offsets = {rhsK} * {Model.RhsStrides[0]} + {rhsN} * {Model.RhsStrides[1]}");
    body.AppendLine($"{Indent(indent + 3)}rhs_offsets = {MaybeVectorizedOffset("rhs_physical_offsets", "rhs_lane[None, :]", Model.RhsNVectorLaneCount)}");
    body.AppendLine($"{Indent(indent + 3)}rhs_ptrs = ({Model.RhsBaseName} + rhs_shard_index * {Model.RhsPoolBytes} + {Model.RhsOffsetBytes}).to(tl.pointer_type({Model.RhsTritonDType}))");
    body.AppendLine($"{Indent(indent + 3)}rhs_mask = (global_k[:, None] < {globalK}) & (offs_n[None, :] < out_n_logical_iter_dim) & (global_n[None, :] < {rhsGlobalLogicalN})");
    body.AppendLine($"{Indent(indent + 3)}rhs_values = tl.load(rhs_ptrs + rhs_offsets, mask=rhs_mask, other=0.0)");
    body.AppendLine($"{Indent(indent + 3)}acc += tl.dot(lhs_values, rhs_values)");

    body.AppendLine($"{Indent(indent + 2)}out_n_physical = offs_n // {Model.OutputNVectorLaneCount}");
    body.AppendLine($"{Indent(indent + 2)}out_lane = offs_n * 0");
    if (Model.OutputNVectorLaneCount != 1)
    {
        body.AppendLine($"{Indent(indent + 2)}out_lane = offs_n % {Model.OutputNVectorLaneCount}");
    }

    body.AppendLine($"{Indent(indent + 2)}output_physical_offsets = offs_m[:, None] * {Model.OutputStrides[0]} + out_n_physical[None, :] * {Model.OutputStrides[1]}");
    body.AppendLine($"{Indent(indent + 2)}output_offsets = {MaybeVectorizedOffset("output_physical_offsets", "out_lane[None, :]", Model.OutputNVectorLaneCount)}");
    body.AppendLine($"{Indent(indent + 2)}output_ptr = ({Model.OutputBaseName} + shard_index * {Model.OutputPoolBytes} + {Model.OutputOffsetBytes}).to(tl.pointer_type({Model.OutputTritonDType}))");
    body.AppendLine($"{Indent(indent + 2)}result = acc * {Model.Scale}");
    body.AppendLine($"{Indent(indent + 2)}output_mask = (offs_m[:, None] < out_m_iter_dim) & (offs_n[None, :] < out_n_logical_iter_dim) & (global_n[None, :] < {outputGlobalLogicalN})");
    body.AppendLine($"{Indent(indent + 2)}tl.store(output_ptr + output_offsets, result, mask=output_mask)");
}
