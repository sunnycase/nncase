@using System.Text
@using Nncase.CodeGen.PyNTT
@model Nncase.CodeGen.PyNTT.PyNTTRoPETemplateModel
@{
    var shape = PyNTTTemplateUtility.ShapeTuple(Model.OutputShape);
    var rank = Model.OutputShape.Length;
    var rotaryAxis = Model.RotaryAxis;
    var outputLaneCount = Model.OutputVectorLaneCount.ToString(System.Globalization.CultureInfo.InvariantCulture);
    var totalElements = Multiply(ProductExpression(Model.OutputShape), outputLaneCount);
    var rotaryExtent = Multiply($"({Model.OutputShape[rotaryAxis].TritonExpression})", outputLaneCount);
    var halfDim = $"(({rotaryExtent}) // 2)";

    static string Indent(int level) => new(' ', level * 4);

    static string ProductExpression(IReadOnlyList<PyNTTDimExpression> values)
    {
        if (values.Count == 0)
        {
            return "1";
        }

        return string.Join(" * ", values.Select(value => $"({value.TritonExpression})"));
    }

    static string Multiply(string lhs, string rhs)
    {
        return rhs == "1" ? lhs : $"({lhs}) * {rhs}";
    }

    string OffsetExpression(PyNTTDimExpression[] operandShape, PyNTTDimExpression[] operandStrides, int operandLaneCount, string rotaryIndex, string laneIndex)
    {
        var axisOffset = rank - operandShape.Length;
        var terms = new List<string>();
        for (var i = 0; i < operandShape.Length; i++)
        {
            if (operandShape[i].IsFixedOne)
            {
                continue;
            }

            var outputAxis = axisOffset + i;
            var index = outputAxis == rotaryAxis ? rotaryIndex : $"idx{outputAxis}";
            terms.Add($"{index} * {operandStrides[i]}");
        }

        var tensorOffset = terms.Count == 0 ? "lane_flat * 0" : string.Join(" + ", terms);
        return operandLaneCount == 1 ? tensorOffset : $"(({tensorOffset}) * {operandLaneCount} + {laneIndex})";
    }

    string OutputOffsetExpression()
    {
        var terms = new List<string>();
        for (var i = 0; i < Model.OutputShape.Length; i++)
        {
            terms.Add($"idx{i} * {Model.OutputStrides[i]}");
        }

        var tensorOffset = terms.Count == 0 ? "lane_flat * 0" : string.Join(" + ", terms);
        return Model.OutputVectorLaneCount == 1 ? tensorOffset : $"(({tensorOffset}) * {Model.OutputVectorLaneCount} + lane_flat)";
    }

    void AppendTensorIndexDecompose(StringBuilder builder, int indent, string linearName, string prefix, IReadOnlyList<PyNTTDimExpression> tensorShape)
    {
        builder.AppendLine($"{Indent(indent)}tmp = {linearName}");
        for (var axis = tensorShape.Count - 1; axis >= 0; axis--)
        {
            builder.AppendLine($"{Indent(indent)}{prefix}{axis} = tmp % {tensorShape[axis]}");
            builder.AppendLine($"{Indent(indent)}tmp = tmp // {tensorShape[axis]}");
        }
    }

    var body = new StringBuilder();
    body.AppendLine($"    for linear_start in tl.range(0, {totalElements}, block_size):");
    body.AppendLine("        linear = linear_start + tl.arange(0, block_size)");
    body.AppendLine($"        mask = linear < {totalElements}");
    body.AppendLine($"        lane_flat = linear % {Model.OutputVectorLaneCount}");
    body.AppendLine($"        output_tensor_linear = linear // {Model.OutputVectorLaneCount}");
    AppendTensorIndexDecompose(body, 2, "output_tensor_linear", "idx", Model.OutputShape);
    body.AppendLine($"        logical_rotary = idx{rotaryAxis} * {Model.OutputVectorLaneCount} + lane_flat");
    body.AppendLine($"        paired_logical = tl.where(logical_rotary < {halfDim}, logical_rotary + {halfDim}, logical_rotary - {halfDim})");
    body.AppendLine($"        paired_idx{rotaryAxis} = paired_logical // {Model.OutputVectorLaneCount}");
    body.AppendLine($"        paired_lane = paired_logical % {Model.OutputVectorLaneCount}");
    body.AppendLine($"        input_offsets = {OffsetExpression(Model.InputShape, Model.InputStrides, Model.InputVectorLaneCount, $"idx{rotaryAxis}", "lane_flat")}");
    body.AppendLine($"        paired_input_offsets = {OffsetExpression(Model.InputShape, Model.InputStrides, Model.InputVectorLaneCount, $"paired_idx{rotaryAxis}", "paired_lane")}");
    body.AppendLine($"        cos_offsets = {OffsetExpression(Model.CosShape, Model.CosStrides, Model.CosVectorLaneCount, $"idx{rotaryAxis}", "lane_flat")}");
    body.AppendLine($"        sin_offsets = {OffsetExpression(Model.SinShape, Model.SinStrides, Model.SinVectorLaneCount, $"idx{rotaryAxis}", "lane_flat")}");
    body.AppendLine($"        output_offsets = {OutputOffsetExpression()}");
    body.AppendLine("        value0 = tl.load(input0 + input_offsets, mask=mask)");
    body.AppendLine("        paired_value = tl.load(input0 + paired_input_offsets, mask=mask)");
    body.AppendLine("        cos_value = tl.load(cos0 + cos_offsets, mask=mask)");
    body.AppendLine("        sin_value = tl.load(sin0 + sin_offsets, mask=mask)");
    body.AppendLine($"        rotated = tl.where(logical_rotary < {halfDim}, -paired_value, paired_value)");
    body.AppendLine("        result = value0 * cos_value + rotated * sin_value");
    body.AppendLine("        tl.store(output + output_offsets, result, mask=mask)");
}
# generated from CodeGen/PyNTT/Templates/Triton/Kernels/RoPE.py.cshtml
# @Model.Comment; input_dtype=@Model.InputDType, cos_dtype=@Model.CosDType, sin_dtype=@Model.SinDType, output_dtype=@Model.OutputDType, shape=@shape, rotary_axis=@Model.RotaryAxis
@@triton.jit
@($"def {Model.FunctionName}(data, rdata, thread_local_rdata, warp_local_rdata, block_local_rdata{PyNTTTemplateUtility.RuntimeParameterSuffix(Model.RuntimeShapeArgs)}):")
    shard_index = tl.program_id(0).to(tl.int64)
    input0 = @Html.Raw(Model.Input.Expression)
    cos0 = @Html.Raw(Model.Cos.Expression)
    sin0 = @Html.Raw(Model.Sin.Expression)
    output = @Html.Raw(Model.Output.Expression)
@Html.Raw(body.ToString().TrimEnd())
