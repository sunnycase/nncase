@using System.Text
@using Nncase.CodeGen.PyNTT
@model Nncase.CodeGen.PyNTT.PyNTTScatterNDTemplateModel
@{
    var inputShape = PyNTTTemplateUtility.ShapeTuple(Model.InputShape);
    var indicesShape = PyNTTTemplateUtility.ShapeTuple(Model.IndicesShape);
    var updatesShape = PyNTTTemplateUtility.ShapeTuple(Model.UpdatesShape);
    var outputShape = PyNTTTemplateUtility.ShapeTuple(Model.OutputShape);
    var inputRank = Model.InputShape.Length;
    var updatesRank = Model.UpdatesShape.Length;
    var indicesRank = Model.IndicesShape.Length;
    var prefixRank = indicesRank - 1;
    var indexDepth = (int)PyNTTTemplateUtility.RequireFixed(Model.IndicesShape[^1], "ScatterND index depth");
    var sliceRank = inputRank - indexDepth;
    var signedIndices = !Model.IndicesDType.StartsWith("uint", StringComparison.Ordinal);

    static string Indent(int level) => new(' ', level * 4);

    string AxisIndex(string prefix, int axis, int blockAxis) => axis == blockAxis ? $"{prefix}_lane" : $"{prefix}_idx{axis}";

    string OffsetExpression(string prefix, PyNTTDimExpression[] shape, PyNTTDimExpression[] strides, int blockAxis)
    {
        var terms = new List<string>();
        for (var axis = 0; axis < shape.Length; axis++)
        {
            terms.Add($"{AxisIndex(prefix, axis, blockAxis)} * {strides[axis]}");
        }

        return terms.Count == 0 ? $"{prefix}_lane * 0" : $"{prefix}_lane * 0 + {string.Join(" + ", terms)}";
    }

    string IndicesPrefixOffsetExpression(int updatesBlockAxis)
    {
        var terms = new List<string>();
        for (var axis = 0; axis < prefixRank; axis++)
        {
            terms.Add($"{AxisIndex("upd", axis, updatesBlockAxis)} * {Model.IndicesStrides[axis]}");
        }

        return terms.Count == 0 ? "upd_lane * 0" : $"upd_lane * 0 + {string.Join(" + ", terms)}";
    }

    string UpdatesOffsetExpression(int updatesBlockAxis)
    {
        var terms = new List<string>();
        for (var axis = 0; axis < updatesRank; axis++)
        {
            terms.Add($"{AxisIndex("upd", axis, updatesBlockAxis)} * {Model.UpdatesStrides[axis]}");
        }

        return terms.Count == 0 ? "upd_lane * 0" : $"upd_lane * 0 + {string.Join(" + ", terms)}";
    }

    string ScatterOutputOffsetExpression(int updatesBlockAxis)
    {
        var terms = new List<string>();
        for (var axis = 0; axis < indexDepth; axis++)
        {
            terms.Add($"scatter_idx{axis} * {Model.OutputStrides[axis]}");
        }

        for (var axis = 0; axis < sliceRank; axis++)
        {
            var updatesAxis = prefixRank + axis;
            var outputAxis = indexDepth + axis;
            terms.Add($"{AxisIndex("upd", updatesAxis, updatesBlockAxis)} * {Model.OutputStrides[outputAxis]}");
        }

        return terms.Count == 0 ? "upd_lane * 0" : $"upd_lane * 0 + {string.Join(" + ", terms)}";
    }

    var copyBlockAxis = PyNTTTemplateUtility.SelectBlockAxis(Model.OutputShape, Model.OutputStrides);
    var copyBlockExtent = Model.OutputShape.Length == 0 ? PyNTTDimExpression.One : Model.OutputShape[copyBlockAxis];
    var copyLoopAxes = Enumerable.Range(0, Model.OutputShape.Length).Where(axis => axis != copyBlockAxis).ToArray();
    var updatesBlockAxis = PyNTTTemplateUtility.SelectBlockAxis(Model.UpdatesShape, Model.UpdatesStrides);
    var updatesBlockExtent = Model.UpdatesShape.Length == 0 ? PyNTTDimExpression.One : Model.UpdatesShape[updatesBlockAxis];
    var updatesLoopAxes = Enumerable.Range(0, Model.UpdatesShape.Length).Where(axis => axis != updatesBlockAxis).ToArray();

    var body = new StringBuilder();
    body.AppendLine($"{Indent(1)}# copy input to output");
    var indent = 1;
    foreach (var axis in copyLoopAxes)
    {
        body.AppendLine($"{Indent(indent)}copy_idx{axis} = 0");
        body.AppendLine($"{Indent(indent)}while copy_idx{axis} < {Model.OutputShape[axis]}:");
        indent++;
    }

    body.AppendLine($"{Indent(indent)}copy_axis_start = 0");
    body.AppendLine($"{Indent(indent)}while copy_axis_start < {copyBlockExtent}:");
    body.AppendLine($"{Indent(indent + 1)}copy_lane = copy_axis_start + tl.arange(0, block_size)");
    body.AppendLine($"{Indent(indent + 1)}copy_mask = copy_lane < {copyBlockExtent}");
    body.AppendLine($"{Indent(indent + 1)}copy_input_offsets = {OffsetExpression("copy", Model.InputShape, Model.InputStrides, copyBlockAxis)}");
    body.AppendLine($"{Indent(indent + 1)}copy_output_offsets = {OffsetExpression("copy", Model.OutputShape, Model.OutputStrides, copyBlockAxis)}");
    body.AppendLine($"{Indent(indent + 1)}copy_value = tl.load(input + copy_input_offsets, mask=copy_mask)");
    body.AppendLine($"{Indent(indent + 1)}tl.store(output + copy_output_offsets, copy_value, mask=copy_mask)");
    body.AppendLine($"{Indent(indent + 1)}copy_axis_start += block_size");
    foreach (var axis in copyLoopAxes.Reverse())
    {
        body.AppendLine($"{Indent(indent)}copy_idx{axis} += 1");
        indent--;
    }

    body.AppendLine();
    body.AppendLine($"{Indent(1)}# scatter updates");
    indent = 1;
    foreach (var axis in updatesLoopAxes)
    {
        body.AppendLine($"{Indent(indent)}upd_idx{axis} = 0");
        body.AppendLine($"{Indent(indent)}while upd_idx{axis} < {Model.UpdatesShape[axis]}:");
        indent++;
    }

    body.AppendLine($"{Indent(indent)}upd_axis_start = 0");
    body.AppendLine($"{Indent(indent)}while upd_axis_start < {updatesBlockExtent}:");
    body.AppendLine($"{Indent(indent + 1)}upd_lane = upd_axis_start + tl.arange(0, block_size)");
    body.AppendLine($"{Indent(indent + 1)}upd_mask = upd_lane < {updatesBlockExtent}");
    body.AppendLine($"{Indent(indent + 1)}indices_prefix_offsets = {IndicesPrefixOffsetExpression(updatesBlockAxis)}");
    for (var axis = 0; axis < indexDepth; axis++)
    {
        body.AppendLine($"{Indent(indent + 1)}scatter_idx{axis} = tl.load(indices + indices_prefix_offsets + {axis} * {Model.IndicesStrides[^1]}, mask=upd_mask, other=0)");
        if (signedIndices)
        {
            body.AppendLine($"{Indent(indent + 1)}scatter_idx{axis} = tl.where(scatter_idx{axis} < 0, scatter_idx{axis} + {Model.OutputShape[axis]}, scatter_idx{axis})");
        }
    }

    body.AppendLine($"{Indent(indent + 1)}updates_offsets = {UpdatesOffsetExpression(updatesBlockAxis)}");
    body.AppendLine($"{Indent(indent + 1)}scatter_output_offsets = {ScatterOutputOffsetExpression(updatesBlockAxis)}");
    body.AppendLine($"{Indent(indent + 1)}updates_value = tl.load(updates + updates_offsets, mask=upd_mask)");
    body.AppendLine($"{Indent(indent + 1)}tl.store(output + scatter_output_offsets, updates_value, mask=upd_mask)");
    body.AppendLine($"{Indent(indent + 1)}upd_axis_start += block_size");
    foreach (var axis in updatesLoopAxes.Reverse())
    {
        body.AppendLine($"{Indent(indent)}upd_idx{axis} += 1");
        indent--;
    }
}
