@using System.Text
@using Nncase.CodeGen.PyNTT
@model Nncase.CodeGen.PyNTT.PyNTTTensorLoadTemplateModel
@{
    var localShape = PyNTTTemplateUtility.ShapeTuple(Model.LocalShape);
    var globalShape = PyNTTTemplateUtility.ShapeTuple(Model.GlobalShape);

    static string Indent(int level) => new(' ', level * 4);

    var globalStrides = PyNTTTemplateUtility.ContiguousStrides(Model.GlobalShape);
    var blockAxis = PyNTTTemplateUtility.SelectBlockAxis(Model.LocalShape, Model.DestinationStrides);
    var blockExtent = Model.LocalShape.Length == 0 ? PyNTTDimExpression.One : Model.LocalShape[blockAxis];
    var loopAxes = Enumerable.Range(0, Model.LocalShape.Length).Where(axis => axis != blockAxis).ToArray();

    string AxisIndex(int axis) => axis == blockAxis ? "lane" : $"idx{axis}";

    string SplitLinearExpression(IReadOnlyList<int> splitAxes)
    {
        if (splitAxes.Count == 0)
        {
            return "0";
        }

        var terms = new List<string>();
        for (var i = 0; i < splitAxes.Count; i++)
        {
            var placementAxis = splitAxes[i];
            var stride = splitAxes.Skip(i + 1).Aggregate(1, (acc, axis) => acc * Model.Hierarchy[axis]);
            terms.Add(stride == 1 ? $"shard_coord{placementAxis}" : $"shard_coord{placementAxis} * {stride}");
        }

        return string.Join(" + ", terms);
    }

    string LocalOffsetExpression()
    {
        var terms = new List<string>();
        for (var i = 0; i < Model.LocalShape.Length; i++)
        {
            terms.Add($"{AxisIndex(i)} * {Model.DestinationStrides[i]}");
        }

        return terms.Count == 0 ? "lane * 0" : $"lane * 0 + {string.Join(" + ", terms)}";
    }

    string SourceOffsetExpression()
    {
        var terms = new List<string>();
        for (var i = 0; i < Model.GlobalShape.Length; i++)
        {
            terms.Add($"global_idx{i} * {globalStrides[i]}");
        }

        return terms.Count == 0 ? "lane * 0" : $"lane * 0 + {string.Join(" + ", terms)}";
    }

    var body = new StringBuilder();
    var indent = 1;
    body.AppendLine($"{Indent(indent)}tmp_shard = shard_index");
    for (var axis = Model.Hierarchy.Length - 1; axis >= 0; axis--)
    {
        body.AppendLine($"{Indent(indent)}shard_coord{axis} = tmp_shard % {Model.Hierarchy[axis]}");
        body.AppendLine($"{Indent(indent)}tmp_shard = tmp_shard // {Model.Hierarchy[axis]}");
    }

    foreach (var axis in loopAxes)
    {
        body.AppendLine($"{Indent(indent)}for idx{axis} in tl.range(0, {Model.LocalShape[axis]}):");
        indent++;
    }

    body.AppendLine($"{Indent(indent)}for axis_start in tl.range(0, {blockExtent}, block_size):");
    body.AppendLine($"{Indent(indent + 1)}lane = axis_start + tl.arange(0, block_size)");
    body.AppendLine($"{Indent(indent + 1)}mask = lane < {blockExtent}");
    for (var axis = 0; axis < Model.GlobalShape.Length; axis++)
    {
        var splitAxes = Model.SplitAxes[axis];
        if (splitAxes.Length == 0)
        {
            body.AppendLine($"{Indent(indent + 1)}global_idx{axis} = {AxisIndex(axis)}");
        }
        else
        {
            var divisor = splitAxes.Aggregate(1, (acc, placementAxis) => acc * Model.Hierarchy[placementAxis]);
            body.AppendLine($"{Indent(indent + 1)}local_dim{axis} = tl.cdiv({Model.GlobalShape[axis]}, {divisor})");
            body.AppendLine($"{Indent(indent + 1)}split_linear{axis} = {SplitLinearExpression(splitAxes)}");
            body.AppendLine($"{Indent(indent + 1)}global_idx{axis} = {AxisIndex(axis)} + split_linear{axis} * local_dim{axis}");
            body.AppendLine($"{Indent(indent + 1)}mask = mask & (global_idx{axis} < {Model.GlobalShape[axis]})");
        }
    }

    body.AppendLine($"{Indent(indent + 1)}source_offsets = {Model.SourceOffset} + {SourceOffsetExpression()}");
    body.AppendLine($"{Indent(indent + 1)}destination_offsets = {LocalOffsetExpression()}");
    body.AppendLine($"{Indent(indent + 1)}value = tl.load(source + source_offsets, mask=mask)");
    body.AppendLine($"{Indent(indent + 1)}tl.store(destination + destination_offsets, value, mask=mask)");

    foreach (var axis in loopAxes.Reverse())
    {
        indent--;
    }
}
# generated from CodeGen/PyNTT/Templates/Triton/Kernels/TensorLoad.py.cshtml
# @Model.Comment; dtype=@Model.DType, local_shape=@localShape, global_shape=@globalShape
@@triton.jit
@($"def {Model.FunctionName}(source, data, rdata, thread_local_rdata, warp_local_rdata, block_local_rdata{PyNTTTemplateUtility.RuntimeParameterSuffix(Model.RuntimeShapeArgs)}):")
    shard_index = tl.program_id(0).to(tl.int64)
    destination = @Html.Raw(Model.Destination.Expression)
@Html.Raw(body.ToString().TrimEnd())
