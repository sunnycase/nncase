@using System.Text
@using Nncase.CodeGen.PyNTT
@model Nncase.CodeGen.PyNTT.PyNTTElementwiseCastTemplateModel
@{
    var shape = PyNTTTemplateUtility.ShapeTuple(Model.Shape);
    var totalElements = ProductExpression(Model.Shape);
    var vectorizedAxis = Model.VectorizedAxes.Length == 0 ? -1 : Model.VectorizedAxes[0];

    static string Indent(int level) => new(' ', level * 4);

    static string ProductExpression(IReadOnlyList<PyNTTDimExpression> values)
    {
        if (values.Count == 0)
        {
            return "1";
        }

        return string.Join(" * ", values.Select(value => $"({value.TritonExpression})"));
    }

    static string TensorOffset(string prefix, IReadOnlyList<PyNTTDimExpression> strides, int laneCount, int vectorizedAxis)
    {
        var terms = new List<string>();
        var laneFlat = "0";
        for (var axis = 0; axis < strides.Count; axis++)
        {
            var index = $"{prefix}{axis}";
            if (axis == vectorizedAxis && laneCount != 1)
            {
                laneFlat = $"{index} % {laneCount}";
                index = $"{index} // {laneCount}";
            }

            terms.Add($"{index} * {strides[axis]}");
        }

        var tensorOffset = terms.Count == 0 ? "linear * 0" : string.Join(" + ", terms);
        return laneCount == 1 ? tensorOffset : $"(({tensorOffset}) * {laneCount} + {laneFlat})";
    }

    void AppendTensorIndexDecompose(StringBuilder builder, int indent, string linearName, string prefix, IReadOnlyList<PyNTTDimExpression> shape)
    {
        builder.AppendLine($"{Indent(indent)}tmp = {linearName}");
        for (var axis = shape.Count - 1; axis >= 0; axis--)
        {
            builder.AppendLine($"{Indent(indent)}{prefix}{axis} = tmp % {shape[axis]}");
            builder.AppendLine($"{Indent(indent)}tmp = tmp // {shape[axis]}");
        }
    }

    var body = new StringBuilder();
    body.AppendLine($"    for linear_start in tl.range(0, {totalElements}, block_size):");
    body.AppendLine("        linear = linear_start + tl.arange(0, block_size)");
    body.AppendLine($"        mask = linear < {totalElements}");
    AppendTensorIndexDecompose(body, 2, "linear", "idx", Model.Shape);
    body.AppendLine($"        input_offsets = {TensorOffset("idx", Model.InputStrides, Model.InputVectorLaneCount, vectorizedAxis)}");
    body.AppendLine($"        output_offsets = {TensorOffset("idx", Model.OutputStrides, Model.OutputVectorLaneCount, vectorizedAxis)}");
    body.AppendLine("        value0 = tl.load(input0 + input_offsets, mask=mask)");
    body.AppendLine($"        result = {Model.CastExpression}");
    body.AppendLine("        tl.store(output + output_offsets, result, mask=mask)");
}
# generated from CodeGen/PyNTT/Templates/Triton/Kernels/ElementwiseCast.py.cshtml
# @Model.Comment; cast_mode=@Model.CastMode, input_dtype=@Model.InputDType, output_dtype=@Model.OutputDType, shape=@shape
@@triton.jit
@($"def {Model.FunctionName}(data, rdata, thread_local_rdata, warp_local_rdata, block_local_rdata{PyNTTTemplateUtility.RuntimeParameterSuffix(Model.RuntimeShapeArgs)}):")
    shard_index = tl.program_id(0).to(tl.int64)
    input0 = @Html.Raw(Model.Input.Expression)
    output = @Html.Raw(Model.Output.Expression)
@Html.Raw(body.ToString().TrimEnd())
