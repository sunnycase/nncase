@using System.Linq
@using NetFabric.Hyperlinq
@using Nncase
@{
  var hierarchy = (int[])Model.Hierarchies;
  var topologyLevels = Model.IsCUDA ? 4 : 3;
}

#pragma once
#include <nncase/ntt/shape.h>

namespace nncase::ntt::distributed {
