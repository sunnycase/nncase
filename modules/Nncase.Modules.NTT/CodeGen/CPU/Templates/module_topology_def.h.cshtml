@using System.Linq
@using NetFabric.Hyperlinq
@using Nncase
@using Nncase.IR
@{
  var options = (Nncase.Targets.NTTTargetOptions)Model.Options;
  var placement = new Placement(options.Hierarchies[0], options.HierarchyNames, options.HierarchyLevels);
  var chipDim = Math.Max(1, placement.GetPhysicalLevelSize('c') * placement.GetPhysicalLevelSize('d'));
  var blockDim = Math.Max(1, placement.GetPhysicalLevelSize('b'));
  var topologyLevels = 2;
  var hierarchy = new[] { chipDim, blockDim };
}

#pragma once
#include <nncase/ntt/shape.h>

namespace nncase::ntt::distributed {
    constexpr auto topology_shape = ntt::fixed_shape_v<@(string.Join(", ", Enumerable.Repeat(1, topologyLevels - hierarchy.Length).Concat(hierarchy)))>;
}
