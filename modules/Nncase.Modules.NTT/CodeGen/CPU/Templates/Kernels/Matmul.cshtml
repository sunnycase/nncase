@model Nncase.CodeGen.NTT.TypedKernelTemplateModel<Nncase.TIR.NTT.Matmul>
@{
  string scale = Model.Arguments[4].Symbol.Name;
  string MatmulLine(bool accumulate, string output) =>
      $"{Model.Indent}  matmul<{accumulate.ToString().ToLowerInvariant()}, {Model.Target.TransposeA.ToString().ToLowerInvariant()}, {Model.Target.TransposeB.ToString().ToLowerInvariant()}>({Model.Arguments[0].Symbol.Name}, {Model.Arguments[1].Symbol.Name}, {output}, {scale}, fixed_shape_v<{string.Join(",", Model.Target.LhsVectorizedAxes)}>, fixed_shape_v<>, fixed_shape_v<{string.Join(",", Model.Target.RhsVectorizedAxes)}>, fixed_shape_v<>);\n";
}

@if (Model.Reduction is { Phase: Nncase.CodeGen.NTT.ReductionKernelPhase.Accumulate } accumulate)
{
@Html.Raw($"{Model.Indent}{{\n")
@Html.Raw($"{Model.Indent}  if ({accumulate.Initialized}) {{\n")
@Html.Raw(MatmulLine(true, accumulate.Accumulators[0]))
@Html.Raw($"{Model.Indent}  }} else {{\n")
@Html.Raw(MatmulLine(false, accumulate.Accumulators[0]))
@Html.Raw($"{Model.Indent}    {accumulate.Initialized} = true;\n")
@Html.Raw($"{Model.Indent}  }}\n")
@Html.Raw($"{Model.Indent}}}\n")
}
else if (Model.Reduction is { Phase: Nncase.CodeGen.NTT.ReductionKernelPhase.Finalize } finalize)
{
@Html.Raw($"{Model.Indent}cast({finalize.Accumulators[0]}, {Model.Arguments[2].Symbol.Name}, fixed_shape_v<>);\n")
}
else
{
@(Model.Indent){
@if (Model.Arguments[3].Symbol.Name != "nullptr")
{
@:@(Model.Indent)if (@Html.Raw(Model.Arguments[3].Symbol.Name)) {
// @:@(Model.Indent)  constexpr std::string_view function_name = "matmul";
// @:@(Model.Indent)  profile_scope profiler(function_name, profile_level::device);
@:@(Model.Indent)  matmul<true, @(Model.Target.TransposeA.ToString().ToLowerInvariant()), @(Model.Target.TransposeB.ToString().ToLowerInvariant())>(@Html.Raw(Model.Arguments[0].Symbol.Name), @Html.Raw(Model.Arguments[1].Symbol.Name), @Html.Raw(Model.Arguments[2].Symbol.Name), @scale, fixed_shape_v<@string.Join(",", Model.Target.LhsVectorizedAxes)>,  fixed_shape_v<>, fixed_shape_v<@string.Join(",", Model.Target.RhsVectorizedAxes)>, fixed_shape_v<>);
@:@(Model.Indent)} else {
// @:@(Model.Indent)  constexpr std::string_view function_name = "matmul";
// @:@(Model.Indent)  profile_scope profiler(function_name, profile_level::device);
@:@(Model.Indent)  matmul<false, @(Model.Target.TransposeA.ToString().ToLowerInvariant()), @(Model.Target.TransposeB.ToString().ToLowerInvariant())>(@Html.Raw(Model.Arguments[0].Symbol.Name), @Html.Raw(Model.Arguments[1].Symbol.Name), @Html.Raw(Model.Arguments[2].Symbol.Name), @scale, fixed_shape_v<@string.Join(",", Model.Target.LhsVectorizedAxes)>,  fixed_shape_v<>, fixed_shape_v<@string.Join(",", Model.Target.RhsVectorizedAxes)>, fixed_shape_v<>);
@:@(Model.Indent)}
}
else
{
// @:@(Model.Indent)  constexpr std::string_view function_name = "matmul";
// @:@(Model.Indent)  profile_scope profiler(function_name, profile_level::device);
@:@(Model.Indent)  matmul<false, @(Model.Target.TransposeA.ToString().ToLowerInvariant()), @(Model.Target.TransposeB.ToString().ToLowerInvariant())>(@Html.Raw(Model.Arguments[0].Symbol.Name), @Html.Raw(Model.Arguments[1].Symbol.Name), @Html.Raw(Model.Arguments[2].Symbol.Name), @scale, fixed_shape_v<@string.Join(",", Model.Target.LhsVectorizedAxes)>,  fixed_shape_v<>, fixed_shape_v<@string.Join(",", Model.Target.RhsVectorizedAxes)>, fixed_shape_v<>);
}
@(Model.Indent)}
}
