{{ "@triton.jit(noinline=True)" if model["NoInline"] else "@triton.jit" }}
def {{ model["FunctionName"] }}({{ helper_parameters(model) }}):
    shard_index = tl.program_id(0).to(tl.int64)
{{ common.shard_coordinates([model["Input"], model["Stats"], model["Scale"], model["Bias"], model["Output"]]) }}
{% for name, key in (("input0", "Input"), ("stats0", "Stats"), ("scale0", "Scale"), ("bias0", "Bias"), ("output", "Output")) %}
{% if local_buffer(model[key]) is none %}
    {{ name }} = {{ ptr(model, key) }}
{% endif %}
{% endfor %}
{% for axis in ctx["outer_axes"] %}
{{ "    " * loop.index }}for outer_idx{{ axis }} in tl.range(0, {{ dim(ctx["logical_output_shape"][axis]) }}):
{% endfor %}
{% set base = "    " * ((ctx["outer_axes"] | length) + 1) %}
{% set body = "    " * ((ctx["outer_axes"] | length) + 2) %}
{{ base }}inner_count = ({{ ctx["normalization_size"] }}) + 0.0
{% if model["UseMean"] %}
{{ base }}mean_sum = tl.load({{ access_pointer(model, "Stats", "stats0", ctx["stats_accesses"][0]) }}).to(tl.float32)
{{ base }}square_sum = tl.load({{ access_pointer(model, "Stats", "stats0", ctx["stats_accesses"][1]) }}).to(tl.float32)
{{ base }}mean_value = mean_sum / inner_count
{{ base }}variance = (square_sum / inner_count) - (mean_value * mean_value)
{% else %}
{{ base }}square_sum = tl.load({{ access_pointer(model, "Stats", "stats0", ctx["stats_accesses"][0]) }}).to(tl.float32)
{{ base }}mean_value = 0.0
{{ base }}variance = square_sum / inner_count
{% endif %}
{{ base }}variance = tl.maximum(variance, 0.0)
{{ base }}inv_std = tl.rsqrt(variance + {{ pyrepr(model["Epsilon"]) }})
{% call(body) elementwise.iterate(ctx, ctx["prefix_depth"]) %}
{{ body }}value0 = tl.load({{ access_pointer(model, "Input", "input0", ctx["input_access"]) }}, mask=mask, other=0.0).to(tl.float32)
{{ body }}scale_value = tl.load({{ access_pointer(model, "Scale", "scale0", ctx["scale_access"]) }}, mask=mask, other=0.0).to(tl.float32)
{{ body }}bias_value = tl.load({{ access_pointer(model, "Bias", "bias0", ctx["bias_access"]) }}, mask=mask, other=0.0).to(tl.float32)
{{ body }}result = ((value0 - mean_value) * inv_std * scale_value) + bias_value
{{ body }}tl.store({{ access_pointer(model, "Output", "output", ctx["output_access"]) }}, result, mask=mask)
{% endcall %}
